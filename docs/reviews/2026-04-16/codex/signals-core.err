    import math
    from datetime import datetime

    if entries is None:
        entries = load_entries()
    now = datetime.now(UTC)
    decay_rate = math.log(2) / halflife_days  # λ = ln(2) / t½

    # Accumulate per-signal: weighted_total, weighted_correct, sum_of_sq_weights
