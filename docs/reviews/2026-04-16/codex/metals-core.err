"C:\\Program Files\\PowerShell\\7\\pwsh.exe" -Command "Get-Content 'Q:\\finance-analyzer-fgl-review\\review_tmp2\\portfolio\\price_targets.py'" in Q:\finance-analyzer-fgl-review
