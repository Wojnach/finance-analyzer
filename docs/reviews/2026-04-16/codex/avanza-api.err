  37:     Uses try/except instead of exists() check to avoid TOCTOU race.
  38:     Handles OSError (permission denied, locked files) gracefully on Windows.
  39:     Logs WARNING on corrupt JSON so corruption is observable (H35).
  40:     """
  41:     path = Path(path)
  42:     try:
  43:         return json.loads(path.read_text(encoding="utf-8"))
  44:     except FileNotFoundError:
  45:         return default
  46:     except OSError:
  47:         # BUG-139: PermissionError (file locked by antivirus/another process)
  48:         # and other OS-level errors should degrade gracefully like missing files.
  49:         logger.debug("load_json: OS error reading %s, returning default", path.name)
  50:         return default
  51:     except (json.JSONDecodeError, ValueError):
  52:         # H35: Log corruption so it's observable — silent defaults hide data loss.
  53:         logger.warning("load_json: corrupt JSON in %s, returning default", path.name)
  54:         return default
