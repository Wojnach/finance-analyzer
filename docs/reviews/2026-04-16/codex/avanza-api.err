 281: # --- Trading functions ---
 282: 
 283: 
 284: def place_buy_order(
 285:     orderbook_id: str,
 286:     price: float,
 287:     volume: int,
 288:     valid_until: date | None = None,
 289: ) -> dict:
 290:     """Place a limit BUY order on Avanza.
 291: 
 292:     Args:
 293:         orderbook_id: Avanza orderbook ID for the instrument
 294:         price: Limit price in SEK
 295:         volume: Number of shares (must be int >= 1)
 296:         valid_until: Order expiry date. Defaults to today (day order).
 297: 
 298:     Returns:
 299:         Dict with orderId, orderRequestStatus, message
 300:     """
 301:     from avanza.constants import OrderType
 302:     return _place_order(orderbook_id, OrderType.BUY, price, volume, valid_until)
 303: 
 304: 
 305: def place_sell_order(
 306:     orderbook_id: str,
 307:     price: float,
 308:     volume: int,
 309:     valid_until: date | None = None,
 310: ) -> dict:
 311:     """Place a limit SELL order on Avanza.
 312: 
 313:     Args:
 314:         orderbook_id: Avanza orderbook ID for the instrument
 315:         price: Limit price in SEK
 316:         volume: Number of shares (must be int >= 1)
 317:         valid_until: Order expiry date. Defaults to today (day order).
 318: 
 319:     Returns:
 320:         Dict with orderId, orderRequestStatus, message
 321:     """
 322:     from avanza.constants import OrderType
 323:     return _place_order(orderbook_id, OrderType.SELL, price, volume, valid_until)
 324: 
 325: 
 326: def _place_order(orderbook_id, order_type, price, volume, valid_until):
 327:     """Internal: place an order via the Avanza API."""
 328:     if volume < 1:
 329:         raise ValueError(f"Volume must be >= 1, got {volume}")
 330:     if price <= 0:
 331:         raise ValueError(f"Price must be > 0, got {price}")
 332: 
 333:     client = get_client()
 334:     account_id = get_account_id()
 335:     expiry = valid_until or date.today()
 336: 
 337:     logger.info(
 338:         "Placing %s order: orderbook=%s price=%.2f vol=%d until=%s account=%s",
 339:         order_type.value, orderbook_id, price, volume, expiry, account_id,
 340:     )
 341:     result = client.place_order(
 342:         account_id=account_id,
 343:         order_book_id=orderbook_id,
 344:         order_type=order_type,
 345:         price=price,
 346:         valid_until=expiry,
 347:         volume=volume,
 348:     )
 349:     logger.info("Order result: %s", result)
 350:     return result
 351: 
 352: 
 353: def get_order_status(order_id: str) -> dict:
 354:     """Check the status of an order by ID.
 355: 
 356:     Returns:
 357:         Order dict with state, price, volume, etc.
 358:     """
 359:     client = get_client()
 360:     account_id = get_account_id()
 361:     return client.get_order(account_id, order_id)
 362: 
 363: 
 364: def delete_order(order_id: str) -> dict:
 365:     """Cancel a pending order.
 366: 
 367:     Returns:
 368:         Dict with orderId, orderRequestStatus, messages
 369:     """
 370:     client = get_client()
 371:     account_id = get_account_id()
 372:     logger.info("Deleting order %s on account %s", order_id, account_id)
 373:     return client.delete_order(account_id, order_id)

