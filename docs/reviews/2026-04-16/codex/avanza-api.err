 136: def get_price(orderbook_id: str) -> dict[str, Any]:
 137:     """Get current price and info for an instrument.
 138: 
 139:     Tries BankID session first, then falls back to TOTP client.
 140: 
 141:     Args:
 142:         orderbook_id: Avanza orderbook ID (numeric string)
 143: 
 144:     Returns:
 145:         Dict with price info including lastPrice, change, changePercent, etc.
 146:     """
 147:     # Try session-based auth first
 148:     if _try_session_auth():
 149:         try:
 150:             from portfolio.avanza_session import get_instrument_price
 151:             return get_instrument_price(orderbook_id)
 152:         except Exception as e:
 153:             logger.warning("Session-based price fetch failed, trying TOTP: %s", e)
 154:             reset_session()
 155: 
 156:     client = get_client()
 157:     info = client.get_stock_info(orderbook_id)
 158:     return info
 159: 
