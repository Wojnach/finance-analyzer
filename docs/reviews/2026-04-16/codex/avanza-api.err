 236: # --- Account ID ---
 237: 
 238: _account_id: str | None = None
 239: 
 240: 
 241: def get_account_id() -> str:
 242:     """Get the trading account ID from Avanza overview (cached).
 243: 
 244:     Scans accounts of type ISK and returns the first one *that is also in
 245:     ALLOWED_ACCOUNT_IDS*. Any ISK account not in the whitelist is rejected.
 246:     This prevents accidental trades on a future-added child ISK, corporate
 247:     ISK, or any account Avanza re-orders into the response.
 248: 
 249:     Returns:
 250:         Account ID string (guaranteed to be in ALLOWED_ACCOUNT_IDS)
 251: 
 252:     Raises:
 253:         RuntimeError: if no whitelisted ISK account is found
 254:     """
 255:     global _account_id
 256:     if _account_id is not None:
 257:         return _account_id
 258:     client = get_client()
 259:     overview = client.get_overview()
 260:     seen_ids: list[str] = []
 261:     for account in overview.get("accounts", []):
 262:         atype = account.get("accountType", "")
 263:         if "ISK" not in atype.upper():
 264:             continue
 265:         candidate = str(account.get("accountId", ""))
 266:         seen_ids.append(candidate)
 267:         # A-AV-2: enforce whitelist BEFORE caching, so a rogue first-call
 268:         # cannot poison the singleton with a non-whitelisted account.
 269:         if candidate in ALLOWED_ACCOUNT_IDS:
 270:             _account_id = candidate
 271:             logger.info("Found whitelisted ISK account: %s", _account_id)
 272:             return _account_id
 273:     raise RuntimeError(
 274:         "No whitelisted ISK account found in Avanza overview. "
 275:         f"ISK account IDs seen: {seen_ids}. Whitelist: {sorted(ALLOWED_ACCOUNT_IDS)}. "
 276:         "If this is a legitimate new account, update ALLOWED_ACCOUNT_IDS in "
 277:         "portfolio/avanza_client.py — never trade on auto-discovered accounts."
 278:     )
 279: 
