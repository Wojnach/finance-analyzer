 101: def load_jsonl_tail(path, max_entries=500, tail_bytes=512_000):
 102:     """Load the last N entries from a JSONL file by reading from the end.
 103: 
 104:     Much more efficient than load_jsonl(limit=N) for large files because
 105:     it only reads the last `tail_bytes` bytes instead of the entire file.
 106: 
 107:     Args:
 108:         path: Path to the .jsonl file.
 109:         max_entries: Maximum entries to return.
 110:         tail_bytes: How many bytes to read from the end of the file.
 111:             Default 512KB ≈ ~1000 typical entries.
 112: 
 113:     Returns:
 114:         list of parsed dicts (chronological order). Empty list if missing.
 115:     """
 116:     path = Path(path)
 117:     try:
 118:         file_size = path.stat().st_size
 119:     except (FileNotFoundError, OSError):
 120:         return []
 121:     if file_size == 0:
 122:         return []
 123: 
 124:     entries = []
 125:     try:
 126:         with open(path, "rb") as f:
 127:             # Seek to near end of file
 128:             offset = max(0, file_size - tail_bytes)
 129:             f.seek(offset)
 130:             data = f.read()
 131:         # Decode and split into lines
 132:         text = data.decode("utf-8", errors="replace")
 133:         lines = text.split("\n")
 134:         # If we seeked mid-file, the first line is likely truncated — skip it
 135:         if offset > 0 and lines:
 136:             lines = lines[1:]
 137:         for line in lines:
 138:             line = line.strip()
 139:             if not line:
 140:                 continue
 141:             try:
 142:                 entries.append(json.loads(line))
 143:             except json.JSONDecodeError:
 144:                 continue
 145:     except (OSError, UnicodeDecodeError) as e:
 146:         logger.debug("load_jsonl_tail failed for %s: %s", path.name, e)
 147:         return []
 148: 
 149:     # Return last max_entries in chronological order
 150:     if len(entries) > max_entries:
 151:         entries = entries[-max_entries:]
 152:     return entries
 153: 
 154: 
 155: def atomic_append_jsonl(path, entry):
 156:     """Append a single JSON entry to a JSONL file.
 157: 
 158:     Uses a write-then-append pattern so partial writes don't corrupt
 159:     existing data. Flushes and fsyncs to ensure durability on crash.
 160:     """
 161:     path = Path(path)
 162:     path.parent.mkdir(parents=True, exist_ok=True)
 163:     line = json.dumps(entry, ensure_ascii=False) + "\n"
 164:     with open(path, "a", encoding="utf-8") as f:
 165:         f.write(line)
 166:         f.flush()
 167:         os.fsync(f.fileno())
 168: 
 169: 
 170: def atomic_write_jsonl(path, entries):
 171:     """Atomically rewrite a JSONL file with the given entries.
 172: 
 173:     Uses tempfile + os.replace so the file is never left partially written.
 174:     """
 175:     path = Path(path)
 176:     path.parent.mkdir(parents=True, exist_ok=True)
 177:     fd, tmp = tempfile.mkstemp(dir=str(path.parent), suffix=".tmp")
 178:     try:
 179:         with os.fdopen(fd, "w", encoding="utf-8") as f:
 180:             for entry in entries:
 181:                 f.write(json.dumps(entry, ensure_ascii=False) + "\n")
 182:             f.flush()
 183:             os.fsync(f.fileno())
 184:         os.replace(tmp, str(path))
 185:     except BaseException:
 186:         with suppress(OSError):
 187:             os.unlink(tmp)
 188:         raise
 189: 
 190: 
 191: def last_jsonl_entry(path, field=None):
 192:     """Return the last parsed JSON entry from a JSONL file (efficient tail read).
 193: 
 194:     Reads only the last 4KB of the file instead of scanning the entire file.
 195: 
 196:     Args:
 197:         path: Path to the JSONL file.
 198:         field: If set, return only this field's value from the last entry.
 199: 
 200:     Returns:
 201:         The last entry (dict) or the value of *field*, or None if file is
 202:         missing/empty/unreadable.
 203:     """
 204:     path = Path(path)
 205:     try:
 206:         file_size = path.stat().st_size
 207:     except (OSError, FileNotFoundError):
 208:         return None
 209:     if file_size == 0:
 210:         return None
 211:     read_size = min(file_size, 4096)
 212:     try:
 213:         with open(path, "rb") as f:
 214:             f.seek(max(0, file_size - read_size))
 215:             tail = f.read().decode("utf-8", errors="replace")
 216:     except OSError:
 217:         return None
 218:     for line in reversed(tail.strip().splitlines()):
 219:         line = line.strip()
 220:         if not line:
 221:             continue
 222:         try:
 223:             entry = json.loads(line)
 224:             if field is not None:
 225:                 return entry.get(field)
 226:             return entry
 227:         except (json.JSONDecodeError, AttributeError):
 228:             continue
 229:     return None
 230: 
 231: 
 232: def prune_jsonl(path, max_entries=5000):
 233:     """Prune a JSONL file to keep only the most recent *max_entries*.
 234: 
 235:     Reads the file, keeps the tail, and atomically rewrites it.
 236:     Skips malformed lines (e.g., from partial writes) during read.
 237:     No-op if the file has fewer entries than *max_entries*.
 238: 
 239:     Returns the number of entries removed, or 0 if no pruning was needed.
 240:     """
 241:     path = Path(path)
 242:     lines = []
 243:     try:
 244:         f = open(path, encoding="utf-8")
 245:     except FileNotFoundError:
 246:         return 0
 247:     with f:
 248:         for line in f:
 249:             stripped = line.strip()
 250:             if not stripped:
 251:                 continue
 252:             # Validate JSON to avoid preserving corrupt partial lines
 253:             try:
 254:                 json.loads(stripped)
 255:                 lines.append(stripped)
 256:             except json.JSONDecodeError:
 257:                 logger.warning("prune_jsonl: skipping malformed line in %s", path.name)
 258:     if len(lines) <= max_entries:
 259:         return 0
 260:     removed = len(lines) - max_entries
 261:     keep = lines[-max_entries:]
 262:     # Atomic rewrite via tempfile
 263:     fd, tmp = tempfile.mkstemp(dir=str(path.parent), suffix=".tmp")
 264:     try:
 265:         with os.fdopen(fd, "w", encoding="utf-8") as f:
 266:             for line in keep:
 267:                 f.write(line + "\n")
 268:             f.flush()
 269:             os.fsync(f.fileno())
 270:         os.replace(tmp, str(path))
 271:     except BaseException:
 272:         with suppress(OSError):
 273:             os.unlink(tmp)
 274:         raise
 275:     logger.info("Pruned %s: removed %d entries, kept %d", path.name, removed, max_entries)
 276:     return removed

