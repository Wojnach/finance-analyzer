--- portfolio/avanza_orders.py:1-380
   1: """Avanza order confirmation flow — human-in-the-loop for real money.
   2: 
   3: Workflow:
   4: 1. Layer 2 calls request_order() → saves intent to pending orders, returns details
   5: 2. Layer 2 sends Telegram message with order details + "Reply CONFIRM to execute"
   6: 3. Main loop calls check_pending_orders() each cycle
   7: 4. On CONFIRM reply → execute order via avanza_control, notify via Telegram
   8: 5. On timeout (5 min) → expire the pending order, notify
   9: """
  10: 
  11: import contextlib
  12: import logging
  13: import uuid
  14: from datetime import UTC, datetime, timedelta
  15: from pathlib import Path
  16: 
  17: from portfolio.avanza_control import place_buy_order, place_sell_order
  18: from portfolio.file_utils import atomic_write_json, load_json
  19: from portfolio.http_retry import fetch_with_retry
  20: from portfolio.telegram_notifications import send_telegram
  21: 
  22: logger = logging.getLogger("portfolio.avanza_orders")
  23: 
  24: DATA_DIR = Path(__file__).resolve().parent.parent / "data"
  25: PENDING_FILE = DATA_DIR / "avanza_pending_orders.json"
  26: EXPIRY_MINUTES = 5
  27: 
  28: 
  29: def _load_pending() -> list[dict]:
  30:     """Load pending orders from disk."""
  31:     result = load_json(PENDING_FILE, default=[])
  32:     if result is None:
  33:         logger.warning("Failed to read pending orders, returning empty")
  34:         return []
  35:     return result
  36: 
  37: 
  38: def _save_pending(orders: list[dict]) -> None:
  39:     """Save pending orders to disk atomically."""
  40:     atomic_write_json(PENDING_FILE, orders)
  41: 
  42: 
  43: def request_order(
  44:     action: str,
  45:     orderbook_id: str,
  46:     instrument_name: str,
  47:     config_key: str,
  48:     volume: int,
  49:     price: float,
  50: ) -> dict:
  51:     """Create a pending order awaiting Telegram confirmation.
  52: 
  53:     Args:
  54:         action: "BUY" or "SELL"
  55:         orderbook_id: Avanza orderbook ID
  56:         instrument_name: Human-readable name (e.g. "SAAB B")
  57:         config_key: Config key (e.g. "SAAB-B")
  58:         volume: Number of shares
  59:         price: Limit price in SEK
  60: 
  61:     Returns:
  62:         The pending order dict (includes id, total_sek, expires)
  63:     """
  64:     if action not in ("BUY", "SELL"):
  65:         raise ValueError(f"action must be BUY or SELL, got {action!r}")
  66:     if volume < 1:
  67:         raise ValueError(f"volume must be >= 1, got {volume}")
  68:     if price <= 0:
  69:         raise ValueError(f"price must be > 0, got {price}")
  70: 
  71:     now = datetime.now(UTC)
  72:     order = {
  73:         "id": str(uuid.uuid4()),
  74:         "timestamp": now.isoformat(),
  75:         "action": action,
  76:         "orderbook_id": str(orderbook_id),
  77:         "instrument_name": instrument_name,
  78:         "config_key": config_key,
  79:         "volume": volume,
  80:         "price": price,
  81:         "total_sek": round(volume * price, 2),
  82:         "status": "pending_confirmation",
  83:         "expires": (now + timedelta(minutes=EXPIRY_MINUTES)).isoformat(),
  84:     }
  85: 
  86:     pending = _load_pending()
  87:     pending.append(order)
  88:     _save_pending(pending)
  89:     logger.info("Order requested: %s %dx %s @ %.2f SEK (id=%s)",
  90:                 action, volume, instrument_name, price, order["id"])
  91:     return order
  92: 
  93: 
  94: def get_pending_orders() -> list[dict]:
  95:     """Get all orders with status 'pending_confirmation'."""
  96:     return [o for o in _load_pending() if o["status"] == "pending_confirmation"]
  97: 
  98: 
  99: def check_pending_orders(config: dict) -> list[dict]:
 100:     """Check for Telegram confirmations and expire stale orders.
 101: 
 102:     Called by the main loop each cycle. Polls Telegram getUpdates for
 103:     CONFIRM replies. Executes confirmed orders and expires timed-out ones.
 104: 
 105:     Args:
 106:         config: App config dict (with telegram.token, telegram.chat_id)
 107: 
 108:     Returns:
 109:         List of orders that were acted on (confirmed or expired) this cycle
 110:     """
 111:     pending = _load_pending()
 112:     if not pending:
 113:         return []
 114: 
 115:     acted_on = []
 116:     now = datetime.now(UTC)
 117: 
 118:     # Check for CONFIRM replies in Telegram
 119:     confirmed = _check_telegram_confirm(config)
 120: 
 121:     # Sort by timestamp descending so CONFIRM matches the most recent pending order
 122:     pending_sorted = sorted(pending, key=lambda o: o.get("timestamp", ""), reverse=True)
 123: 
 124:     for order in pending_sorted:
 125:         if order["status"] != "pending_confirmation":
 126:             continue
 127: 
 128:         expires = datetime.fromisoformat(order["expires"])
 129: 
 130:         if confirmed:
 131:             # Confirm the most recent pending order
 132:             order["status"] = "confirmed"
 133:             acted_on.append(order)
 134:             confirmed = False  # One CONFIRM per order
 135:             _execute_confirmed_order(order, config)
 136: 
 137:         elif now > expires:
 138:             order["status"] = "expired"
 139:             acted_on.append(order)
 140:             _notify_expired(order, config)
 141: 
 142:     _save_pending(pending)
 143:     return acted_on
 144: 
 145: 
 146: def _check_telegram_confirm(config: dict) -> bool:
 147:     """Poll Telegram for a CONFIRM reply from the configured chat.
 148: 
 149:     Uses getUpdates with a stored offset to avoid reprocessing old messages.
 150:     """
 151:     token = config.get("telegram", {}).get("token", "")
 152:     chat_id = str(config.get("telegram", {}).get("chat_id", ""))
 153:     if not token or not chat_id:
 154:         return False
 155: 
 156:     # Load stored offset (BUG-128: now atomic JSON; handles legacy plain-text format)
 157:     offset_file = DATA_DIR / "avanza_telegram_offset.txt"
 158:     offset = 0
 159:     offset_data = load_json(offset_file)
 160:     if isinstance(offset_data, dict):
 161:         offset = int(offset_data.get("offset", 0))
 162:     elif offset_file.exists():
 163:         with contextlib.suppress(ValueError, OSError):
 164:             offset = int(offset_file.read_text().strip())
 165: 
 166:     params = {"timeout": 1, "allowed_updates": ["message"]}
 167:     if offset:
 168:         params["offset"] = offset
 169: 
 170:     try:
 171:         r = fetch_with_retry(
 172:             f"https://api.telegram.org/bot{token}/getUpdates",
 173:             params=params,
 174:             timeout=5,
 175:         )
 176:         if r is None or not r.ok:
 177:             return False
 178:         data = r.json()
 179:         if not data.get("ok"):
 180:             return False
 181:     except Exception as e:
 182:         logger.warning("Telegram getUpdates failed: %s", e)
 183:         return False
 184: 
 185:     found_confirm = False
 186:     for update in data.get("result", []):
 187:         update_id = update.get("update_id", 0)
 188:         # Always advance offset
 189:         if update_id >= offset:
 190:             offset = update_id + 1
 191: 
 192:         msg = update.get("message", {})
 193:         if str(msg.get("chat", {}).get("id")) != chat_id:
 194:             continue
 195: 
 196:         text = (msg.get("text") or "").strip().upper()
 197:         if text == "CONFIRM":
 198:             found_confirm = True
 199: 
 200:     # Save offset atomically to prevent corruption on crash (BUG-128)
 201:     try:
 202:         atomic_write_json(offset_file, {"offset": offset})
 203:     except OSError as e:
 204:         logger.warning("Failed to save Telegram offset: %s", e)
 205: 
 206:     return found_confirm
 207: 
 208: 
 209: def _execute_confirmed_order(order: dict, config: dict) -> None:
 210:     """Execute a confirmed order on Avanza and notify via Telegram."""
 211:     action = order["action"]
 212:     try:
 213:         if action == "BUY":
 214:             result = place_buy_order(
 215:                 orderbook_id=order["orderbook_id"],
 216:                 price=order["price"],
 217:                 volume=order["volume"],
 218:             )
 219:         else:
 220:             result = place_sell_order(
 221:                 orderbook_id=order["orderbook_id"],
 222:                 price=order["price"],
 223:                 volume=order["volume"],
 224:             )
 225: 
 226:         status = result.get("orderRequestStatus", "UNKNOWN")
 227:         order_id = result.get("orderId", "?")
 228:         msg_text = result.get("message", "")
 229: 
 230:         if status == "SUCCESS":
 231:             order["status"] = "executed"
 232:             order["avanza_order_id"] = order_id
 233:             msg = (
 234:                 f"AVANZA {action} EXECUTED\n"
 235:                 f"{order['instrument_name']}: {order['volume']}x @ {order['price']:.2f} SEK\n"
 236:                 f"Total: {order['total_sek']:,.0f} SEK\n"
 237:                 f"Order ID: {order_id}"
 238:             )
 239:             logger.info("Order executed: %s (avanza_id=%s)", order["id"], order_id)
 240:         else:
 241:             order["status"] = "failed"
 242:             order["error"] = msg_text
 243:             msg = (
 244:                 f"AVANZA {action} FAILED\n"
 245:                 f"{order['instrument_name']}: {order['volume']}x @ {order['price']:.2f} SEK\n"
 246:                 f"Error: {msg_text}"
 247:             )
 248:             logger.error("Order failed: %s — %s", order["id"], msg_text)
 249: 
 250:         send_telegram(msg, config)
 251: 
 252:     except Exception as e:
 253:         order["status"] = "error"
 254:         order["error"] = str(e)
 255:         logger.error("Order execution error: %s — %s", order["id"], e)
 256:         try:
 257:             send_telegram(
 258:                 f"AVANZA ORDER ERROR\n{order['instrument_name']}: {e}",
 259:                 config,
 260:             )
 261:         except Exception as e:
 262:             logger.warning("Order error notification failed: %s", e)
 263: 
 264: 
 265: def _notify_expired(order: dict, config: dict) -> None:
 266:     """Notify via Telegram that a pending order expired."""
 267:     msg = (
 268:         f"AVANZA ORDER EXPIRED\n"
 269:         f"{order['action']} {order['instrument_name']}: "
 270:         f"{order['volume']}x @ {order['price']:.2f} SEK\n"
 271:         f"No confirmation received within {EXPIRY_MINUTES} min."
 272:     )
 273:     logger.info("Order expired: %s", order["id"])
 274:     try:
 275:         send_telegram(msg, config)
 276:     except Exception as e:
 277:         logger.warning("Failed to send expiry notification: %s", e)

--- portfolio/avanza_order_lock.py:1-220
   1: """Cross-process advisory file lock guarding Avanza order placement.
   2: 
   3: Used across metals_loop, golddigger, fin_snipe_manager (and any future
   4: Avanza-bound loop) to prevent two processes submitting overlapping orders
   5: when they observe the same ``buying_power`` simultaneously. Without this,
   6: the following sequence is possible:
   7: 
   8:     t=0.00  metals_loop reads buying_power=6000 SEK
   9:     t=0.05  golddigger reads buying_power=6000 SEK
  10:     t=0.10  metals_loop POSTs order for 5000 SEK
  11:     t=0.15  golddigger POSTs order for 5000 SEK
  12:     t=0.20  Avanza rejects one / or both fill and settlement overdraws
  13: 
  14: READ paths (``fetch_price``, ``fetch_positions``, ``buying_power``) are
  15: NOT guarded — they're safe to run concurrently, and the whole point of
  16: the resilience refactor is to keep those fast.
  17: 
  18: Usage:
  19: 
  20:     from portfolio.avanza_order_lock import avanza_order_lock
  21: 
  22:     with avanza_order_lock(op="place_order"):
  23:         resp = api_post("/_api/trading-critical/rest/order/new", payload)
  24: 
  25: Design notes:
  26: 
  27: * ``filelock.FileLock`` is already in requirements (3.20.3 as of 2026-04-13).
  28: * 2-second fail-fast default — long enough to ride through a normal order
  29:   round-trip (~300ms), short enough that a hung peer doesn't block trading.
  30: * Raises ``OrderLockBusyError`` on timeout so callers can log + retry next
  31:   cycle instead of blocking the whole loop.
  32: * Caller-provided ``op`` label threads through to log messages for
  33:   diagnostics ("which loop hit the busy lock").
  34: """
  35: 
  36: from __future__ import annotations
  37: 
  38: import logging
  39: from collections.abc import Iterator
  40: from contextlib import contextmanager
  41: from pathlib import Path
  42: 
  43: import filelock
  44: 
  45: logger = logging.getLogger("portfolio.avanza_order_lock")
  46: 
  47: BASE_DIR = Path(__file__).resolve().parent.parent
  48: DATA_DIR = BASE_DIR / "data"
  49: LOCK_FILE = DATA_DIR / "avanza_order.lock"
  50: 
  51: DEFAULT_TIMEOUT_S = 2.0
  52: 
  53: 
  54: class OrderLockBusyError(Exception):
  55:     """Another process held the lock longer than the configured timeout."""
  56: 
  57: 
  58: @contextmanager
  59: def avanza_order_lock(
  60:     *,
  61:     timeout_s: float = DEFAULT_TIMEOUT_S,
  62:     op: str = "order",
  63:     lock_file: Path | None = None,
  64: ) -> Iterator[filelock.FileLock]:
  65:     """Acquire the cross-process Avanza order lock for a short critical section.
  66: 
  67:     Fail-fast after ``timeout_s``. The lock is released automatically on exit.
  68: 
  69:     Args:
  70:         timeout_s: Seconds to wait for the lock before raising
  71:             :class:`OrderLockBusyError`. Default 2.0 — short enough to abort
  72:             a stuck caller, long enough to ride through a normal order RTT.
  73:         op: Short label for the operation, threaded into log messages.
  74:         lock_file: Override the lock path (tests only). Defaults to
  75:             ``data/avanza_order.lock``.
  76: 
  77:     Raises:
  78:         OrderLockBusyError: If another process held the lock longer than
  79:             ``timeout_s`` seconds.
  80:     """
  81:     target = Path(lock_file) if lock_file is not None else LOCK_FILE
  82:     target.parent.mkdir(parents=True, exist_ok=True)
  83:     lock = filelock.FileLock(str(target), timeout=timeout_s)
  84:     try:
  85:         lock.acquire()
  86:     except filelock.Timeout as exc:
  87:         logger.warning(
  88:             "avanza_order_lock(%s): busy after %.1fs — another process holds the lock",
  89:             op, timeout_s,
  90:         )
  91:         raise OrderLockBusyError(f"lock busy after {timeout_s}s (op={op})") from exc
  92:     try:
  93:         logger.debug("avanza_order_lock(%s): acquired", op)
  94:         yield lock
  95:     finally:
  96:         try:
  97:             lock.release()
  98:             logger.debug("avanza_order_lock(%s): released", op)
  99:         except Exception as exc:
 100:             logger.warning("avanza_order_lock(%s): release failed: %s", op, exc)

--- portfolio/avanza_session.py:230-520
 230: # --- API convenience functions ---
 231: 
 232: 
 233: def api_get(path: str, **kwargs) -> Any:
 234:     """Make an authenticated GET request to Avanza API.
 235: 
 236:     Args:
 237:         path: API path (e.g., "/_api/position-data/positions")
 238: 
 239:     Returns:
 240:         Parsed JSON response.
 241: 
 242:     Raises:
 243:         AvanzaSessionError: if session is invalid.
 244:     """
 245:     # A-AV-1: Hold _pw_lock for the entire request. Playwright's sync_api
 246:     # is NOT thread-safe and the metals fast-tick + main 8-worker pool race.
 247:     # 2026-04-13: Wrapped in _with_browser_recovery so TargetClosedError
 248:     # (browser died mid-flight) triggers a teardown + relaunch + retry.
 249:     url = f"{API_BASE}{path}" if path.startswith("/") else path
 250: 
 251:     def _op(ctx):
 252:         resp = ctx.request.get(url)
 253:         if resp.status == 401:
 254:             close_playwright()
 255:             raise AvanzaSessionError(
 256:                 "Session returned 401 Unauthorized. "
 257:                 "Run: python scripts/avanza_login.py"
 258:             )
 259:         if not resp.ok:
 260:             raise RuntimeError(f"Avanza API error {resp.status}: {resp.text()[:500]}")
 261:         return resp.json()
 262: 
 263:     return _with_browser_recovery(_op, op_name=f"GET {path}")
 264: 
 265: 
 266: def _get_csrf(ctx=None) -> str:
 267:     """Extract CSRF token from Playwright context cookies.
 268: 
 269:     If ``ctx`` is provided (e.g. from inside an already-locked _with_recovery
 270:     block) it is used directly — avoids re-entering the RLock and avoids a
 271:     stale context reference after a relaunch. Otherwise acquires the lock
 272:     and fetches a fresh context.
 273:     """
 274:     if ctx is not None:
 275:         for c in ctx.cookies():
 276:             if c["name"] == "AZACSRF":
 277:                 return c["value"]
 278:         raise AvanzaSessionError("No AZACSRF cookie found — session may be invalid")
 279: 
 280:     # A-AV-1: ctx.cookies() reads Playwright internal state — needs lock.
 281:     with _pw_lock:
 282:         ctx = _get_playwright_context()
 283:         for c in ctx.cookies():
 284:             if c["name"] == "AZACSRF":
 285:                 return c["value"]
 286:         raise AvanzaSessionError("No AZACSRF cookie found — session may be invalid")
 287: 
 288: 
 289: def api_post(path: str, payload: dict) -> Any:
 290:     """Make an authenticated POST request to Avanza API.
 291: 
 292:     Automatically includes the X-SecurityToken (CSRF) header.
 293: 
 294:     Args:
 295:         path: API path (e.g., "/_api/trading-critical/rest/order/new")
 296:         payload: Request body dict.
 297: 
 298:     Returns:
 299:         Parsed JSON response.
 300:     """
 301:     # A-AV-1: Hold lock across CSRF read + POST so a concurrent request
 302:     # cannot rotate the cookie jar mid-flight.
 303:     # 2026-04-13: Wrapped in _with_browser_recovery. CSRF is read from the
 304:     # same ctx used for the POST, so a relaunch picks up fresh cookies in
 305:     # both places atomically (no stale-CSRF-against-fresh-context mismatch).
 306:     url = f"{API_BASE}{path}" if path.startswith("/") else path
 307:     body_data = json.dumps(payload)
 308: 
 309:     def _op(ctx):
 310:         csrf = _get_csrf(ctx)
 311:         resp = ctx.request.post(
 312:             url,
 313:             data=body_data,
 314:             headers={
 315:                 "Content-Type": "application/json",
 316:                 "X-SecurityToken": csrf,
 317:             },
 318:         )
 319:         if resp.status == 401:
 320:             close_playwright()
 321:             raise AvanzaSessionError(
 322:                 "Session returned 401 Unauthorized. "
 323:                 "Run: python scripts/avanza_login.py"
 324:             )
 325:         if resp.status == 403:
 326:             close_playwright()
 327:             raise AvanzaSessionError(
 328:                 "Session returned 403 Forbidden — CSRF token may be stale. "
 329:                 "Run: python scripts/avanza_login.py"
 330:             )
 331:         body = resp.text()
 332:         try:
 333:             return json.loads(body)
 334:         except (json.JSONDecodeError, TypeError):
 335:             if not resp.ok:
 336:                 raise RuntimeError(f"Avanza API error {resp.status}: {body[:500]}") from None
 337:             return {"raw": body}
 338: 
 339:     return _with_browser_recovery(_op, op_name=f"POST {path}")
 340: 
 341: 
 342: def api_delete(path: str) -> Any:
 343:     """Make an authenticated DELETE request to Avanza API.
 344: 
 345:     Automatically includes the X-SecurityToken (CSRF) header.
 346: 
 347:     Args:
 348:         path: API path (e.g., "/_api/trading/stoploss/{stop_id}")
 349: 
 350:     Returns:
 351:         Dict with ``http_status`` and ``ok`` keys.
 352:     """
 353:     # A-AV-1: Hold lock across CSRF read + DELETE.
 354:     # 2026-04-13: Wrapped in _with_browser_recovery (see api_get/api_post).
 355:     url = f"{API_BASE}{path}" if path.startswith("/") else path
 356: 
 357:     def _op(ctx):
 358:         csrf = _get_csrf(ctx)
 359:         resp = ctx.request.delete(
 360:             url,
 361:             headers={
 362:                 "Content-Type": "application/json",
 363:                 "X-SecurityToken": csrf,
 364:             },
 365:         )
 366:         if resp.status == 401:
 367:             close_playwright()
 368:             raise AvanzaSessionError(
 369:                 "Session returned 401 Unauthorized. "
 370:                 "Run: python scripts/avanza_login.py"
 371:             )
 372:         return {"http_status": resp.status, "ok": 200 <= resp.status < 300 or resp.status == 404}
 373: 
 374:     return _with_browser_recovery(_op, op_name=f"DELETE {path}")
 375: 
 376: 
 377: # --- Trading convenience functions ---
 378: 
 379: 
 380: def get_buying_power(account_id: str | None = None) -> dict | None:
 381:     """Get buying power and account value for an account.
 382: 
 383:     2026-04-09 (Bug C7 fix): ported the multi-shape + multi-field-ID fallback
 384:     pattern from ``data/metals_avanza_helpers.fetch_account_cash`` after Avanza
 385:     changed the ``/_api/account-overview/overview/categorizedAccounts`` response
 386:     shape mid-day. The endpoint used to return a single top-level key
 387:     ``categorizedAccounts`` (an array of categories each with an ``accounts``
 388:     child). The new shape exposes three top-level keys simultaneously:
 389:     ``categories`` (new categorized path), ``accounts`` (flat list of all user
 390:     accounts), and ``loans``. At the same time, the per-account ID field
 391:     renamed from ``accountId`` to ``id`` (the other Avanza endpoints such as
 392:     ``position-data/positions`` already use ``id`` — see ``get_positions``).
 393: 
 394:     Previously this function assumed the legacy shape + legacy ID field, so on
 395:     the new shape the iteration walked an empty list, then hit ``cats[0]`` on
 396:     an empty list (IndexError) or — if the shape still exposed the legacy key
 397:     but with no matches — silently returned fake numbers derived from the
 398:     first category's totalValue. That made callers like ``fish_straddle`` and
 399:     ``fish_monitor_live`` size positions off wrong cash balances.
 400: 
 401:     We now try all three shapes (legacy categorized → flat → new categorized)
 402:     and all four known ID fields (``accountId``, ``id``, ``accountNumber``,
 403:     ``number``), taking whichever finds the target account first. On any
 404:     failure path we return ``None`` so callers can distinguish "API call failed"
 405:     from "balance is legitimately zero" — callers must now explicitly handle
 406:     the ``None`` case (previously they silently got ``buying_power=0``, which
 407:     was a dangerous silent failure).
 408: 
 409:     Args:
 410:         account_id: Avanza account ID (default: ``DEFAULT_ACCOUNT_ID``).
 411: 
 412:     Returns:
 413:         Dict with ``buying_power``, ``total_value``, ``own_capital`` (all SEK)
 414:         on success. ``None`` on any failure (HTTP error, account not found,
 415:         shape drift, etc.). Failures are logged with enough diagnostic context
 416:         (sample keys, counts per shape) to identify the next shape drift
 417:         without guessing.
 418:     """
 419:     aid = str(account_id or DEFAULT_ACCOUNT_ID)
 420: 
 421:     try:
 422:         data = api_get("/_api/account-overview/overview/categorizedAccounts")
 423:     except Exception as e:
 424:         logger.warning(
 425:             "get_buying_power: api_get raised account_id=%s exception=%r",
 426:             aid, e,
 427:         )
 428:         return None
 429: 
 430:     if not isinstance(data, dict):
 431:         logger.warning(
 432:             "get_buying_power: unexpected response type account_id=%s type=%s",
 433:             aid, type(data).__name__,
 434:         )
 435:         return None
 436: 
 437:     def _v(obj):
 438:         """Unwrap Avanza {value: N} wrappers → N, else return obj as-is."""
 439:         if isinstance(obj, dict) and "value" in obj:
 440:             return obj["value"]
 441:         return obj
 442: 
 443:     def _get_acc_id(acc: dict) -> str | None:
 444:         """Try every known ID field in order — matches fetch_account_cash.
 445: 
 446:         Order preserved from the reference JS implementation so a regression
 447:         hitting one file makes the other equally easy to diagnose.
 448:         """
 449:         if not isinstance(acc, dict):
 450:             return None
 451:         for key in ("accountId", "id", "accountNumber", "number"):
 452:             val = acc.get(key)
 453:             if val is not None:
 454:                 return str(val)
 455:         return None
 456: 
 457:     def _get_balance(acc: dict, primary: str, alternates: tuple[str, ...]):
 458:         """Try primary balance field, fall back to alternates.
 459: 
 460:         2026-04-09: we haven't confirmed whether `buyingPower` survived the
 461:         shape change, so we try common alternates if the primary is missing.
 462:         Mirrors getBalance() in fetch_account_cash.
 463:         """
 464:         p = _v(acc.get(primary))
 465:         if p is not None:
 466:             return p
 467:         for alt in alternates:
 468:             x = _v(acc.get(alt))
 469:             if x is not None:
 470:                 return x
 471:         return None
 472: 
 473:     def _make_result(acc: dict) -> dict:
 474:         return {
 475:             "buying_power": _get_balance(
 476:                 acc, "buyingPower",
 477:                 ("buyingPowerAvailable", "availableCash", "availableFunds"),
 478:             ),
 479:             "total_value": _get_balance(
 480:                 acc, "totalValue",
 481:                 ("accountTotalValue", "totalHoldings"),
 482:             ),
 483:             "own_capital": _get_balance(
 484:                 acc, "ownCapital",
 485:                 ("netDeposit", "selfOwnedCapital"),
 486:             ),
 487:         }
 488: 
 489:     ids_seen: list[str] = []
 490:     sample_account_keys: list[str] | None = None
 491: 
 492:     def _check_account(acc: dict) -> dict | None:
 493:         nonlocal sample_account_keys
 494:         if sample_account_keys is None and isinstance(acc, dict):
 495:             sample_account_keys = list(acc.keys())
 496:         acc_id = _get_acc_id(acc)
 497:         if acc_id is not None:
 498:             ids_seen.append(acc_id)
 499:         if acc_id == aid:
 500:             return _make_result(acc)
 501:         return None
 502: 
 503:     # Path A (legacy, pre-2026-04-09): data.categorizedAccounts[].accounts[]
 504:     legacy_cats = data.get("categorizedAccounts") or []
 505:     for cat in legacy_cats:
 506:         for acc in (cat.get("accounts") or []):
 507:             r = _check_account(acc)
 508:             if r is not None:
 509:                 return r
 510: 
 511:     # Path B (new flat shape, 2026-04-09): data.accounts[]
 512:     flat_accounts = data.get("accounts") or []
 513:     for acc in flat_accounts:
 514:         r = _check_account(acc)
 515:         if r is not None:
 516:             return r
 517: 
 518:     # Path C (new categorized shape, 2026-04-09): data.categories[].accounts[]
 519:     new_cats = data.get("categories") or []
 520:     for cat in new_cats:

--- portfolio/avanza_session.py:520-980
 520:     for cat in new_cats:
 521:         for acc in (cat.get("accounts") or []):
 522:             r = _check_account(acc)
 523:             if r is not None:
 524:                 return r
 525: 
 526:     # Total miss — log the full diagnostic so the next shape drift is obvious.
 527:     logger.warning(
 528:         "get_buying_power: no_account_match account_id=%s "
 529:         "legacy_category_count=%d flat_account_count=%d new_category_count=%d "
 530:         "ids_seen=%s sample_account_keys=%s top_level_keys=%s",
 531:         aid, len(legacy_cats), len(flat_accounts), len(new_cats),
 532:         ids_seen, sample_account_keys, list(data.keys()),
 533:     )
 534:     return None
 535: 
 536: 
 537: def place_buy_order(
 538:     orderbook_id: str,
 539:     price: float,
 540:     volume: int,
 541:     account_id: str | None = None,
 542:     valid_until: str | None = None,
 543: ) -> dict:
 544:     """Place a limit BUY order on Avanza.
 545: 
 546:     Args:
 547:         orderbook_id: Avanza orderbook ID.
 548:         price: Limit price in SEK.
 549:         volume: Number of units (int >= 1).
 550:         account_id: Defaults to DEFAULT_ACCOUNT_ID.
 551:         valid_until: ISO date string. Defaults to today (day order).
 552: 
 553:     Returns:
 554:         Dict with orderRequestStatus, orderId, message.
 555:     """
 556:     return _place_order("BUY", orderbook_id, price, volume, account_id, valid_until)
 557: 
 558: 
 559: def place_sell_order(
 560:     orderbook_id: str,
 561:     price: float,
 562:     volume: int,
 563:     account_id: str | None = None,
 564:     valid_until: str | None = None,
 565: ) -> dict:
 566:     """Place a limit SELL order on Avanza."""
 567:     return _place_order("SELL", orderbook_id, price, volume, account_id, valid_until)
 568: 
 569: 
 570: def _place_order(
 571:     side: str,
 572:     orderbook_id: str,
 573:     price: float,
 574:     volume: int,
 575:     account_id: str | None = None,
 576:     valid_until: str | None = None,
 577: ) -> dict:
 578:     """Internal: place a BUY or SELL limit order."""
 579:     if volume < 1:
 580:         raise ValueError(f"volume must be >= 1, got {volume}")
 581:     if price <= 0:
 582:         raise ValueError(f"price must be > 0, got {price}")
 583: 
 584:     # H7: account whitelist guard
 585:     effective_account_id = str(account_id or DEFAULT_ACCOUNT_ID)
 586:     if effective_account_id not in ALLOWED_ACCOUNT_IDS:
 587:         raise ValueError(f"Refusing to trade on non-whitelisted account {effective_account_id!r}")
 588: 
 589:     # H8: minimum order size guard
 590:     order_total = round(volume * price, 2)
 591:     if order_total < 1000.0:
 592:         raise ValueError(f"Order total {order_total:.2f} SEK below minimum 1000 SEK")
 593: 
 594:     payload = {
 595:         "accountId": effective_account_id,
 596:         "orderbookId": str(orderbook_id),
 597:         "side": side,
 598:         "condition": "NORMAL",
 599:         "price": price,
 600:         "validUntil": valid_until or date.today().isoformat(),
 601:         "volume": volume,
 602:     }
 603:     # 2026-04-13: cross-process lock — metals_loop + golddigger + fin_snipe
 604:     # must not race on buying_power. 2s fail-fast; busy peer aborts the order
 605:     # (caller retries next cycle).
 606:     with avanza_order_lock(op=f"place_order/{side}/{orderbook_id}"):
 607:         result = api_post("/_api/trading-critical/rest/order/new", payload)
 608:     status = result.get("orderRequestStatus", "UNKNOWN")
 609:     if status != "SUCCESS":
 610:         logger.warning("Order %s failed: %s — %s", side, status, result.get("message", ""))
 611:     else:
 612:         logger.info(
 613:             "Order %s placed: %dx @ %.3f SEK (id=%s)",
 614:             side, volume, price, result.get("orderId", "?"),
 615:         )
 616:     return result
 617: 
 618: 
 619: def cancel_order(order_id: str, account_id: str | None = None) -> dict:
 620:     """Cancel an open order.
 621: 
 622:     IMPORTANT: Uses POST (not DELETE verb) — Avanza API change 2026-03-24.
 623:     """
 624:     payload = {
 625:         "accountId": str(account_id or DEFAULT_ACCOUNT_ID),
 626:         "orderId": str(order_id),
 627:     }
 628:     # 2026-04-13: cross-process order lock — cancel is a mutation, same
 629:     # concurrency concern as place_order (don't want two cancels racing).
 630:     with avanza_order_lock(op=f"cancel_order/{order_id}"):
 631:         return api_post("/_api/trading-critical/rest/order/delete", payload)
 632: 
 633: 
 634: def get_open_orders(account_id: str | None = None) -> list[dict]:
 635:     """Get all open (unfilled) orders for an account."""
 636:     aid = str(account_id or DEFAULT_ACCOUNT_ID)
 637:     try:
 638:         data = api_get(f"/_api/trading/rest/order/account/{aid}")
 639:         if isinstance(data, list):
 640:             return data
 641:         return data.get("orders", data.get("openOrders", []))
 642:     except RuntimeError:
 643:         # Endpoint may vary — fallback to deal endpoint
 644:         try:
 645:             data = api_get("/_api/trading/rest/deals-and-orders")
 646:             orders = data.get("orders", [])
 647:             return [o for o in orders if str(o.get("accountId", "")) == aid]
 648:         except RuntimeError:
 649:             logger.warning("Could not fetch open orders")
 650:             return []
 651: 
 652: 
 653: def get_quote(orderbook_id: str) -> dict:
 654:     """Get bid/ask/last quote for an instrument. Fast single-endpoint call.
 655: 
 656:     Returns:
 657:         Dict with buy, sell, last, changePercent, highest, lowest.
 658:     """
 659:     return api_get(f"/_api/market-guide/stock/{orderbook_id}/quote")
 660: 
 661: 
 662: def get_positions() -> list[dict]:
 663:     """Get all positions via session-based auth.
 664: 
 665:     Returns:
 666:         List of position dicts with name, value, profit, etc.
 667:     """
 668:     data = api_get("/_api/position-data/positions")
 669:     positions = []
 670:     for entry in data.get("withOrderbook", []):
 671:         inst = entry.get("instrument", {})
 672:         orderbook = inst.get("orderbook", {})
 673:         quote = orderbook.get("quote", {})
 674:         volume_obj = entry.get("volume", {})
 675:         value_obj = entry.get("value", {})
 676:         acquired_obj = entry.get("acquiredValue", {})
 677:         account = entry.get("account", {})
 678: 
 679:         vol = volume_obj.get("value", 0) if isinstance(volume_obj, dict) else volume_obj
 680:         val = value_obj.get("value", 0) if isinstance(value_obj, dict) else value_obj
 681:         acq = acquired_obj.get("value", 0) if isinstance(acquired_obj, dict) else acquired_obj
 682:         latest = quote.get("latest", {})
 683:         last_price = latest.get("value", 0) if isinstance(latest, dict) else latest
 684:         change_pct_obj = quote.get("changePercent", {})
 685:         change_pct = change_pct_obj.get("value", 0) if isinstance(change_pct_obj, dict) else change_pct_obj
 686: 
 687:         positions.append({
 688:             "name": inst.get("name", orderbook.get("name", "")),
 689:             "orderbook_id": str(orderbook.get("id", "")),
 690:             "instrument_id": str(inst.get("id", "")),
 691:             "type": inst.get("type", orderbook.get("type", "")),
 692:             "volume": vol,
 693:             "value": val,
 694:             "acquired_value": acq,
 695:             "profit": val - acq if val and acq else 0,
 696:             "profit_percent": ((val - acq) / acq * 100) if acq else 0,
 697:             "currency": inst.get("currency", "SEK"),
 698:             "last_price": last_price,
 699:             "change_percent": change_pct,
 700:             "account_id": account.get("id", ""),
 701:             "account_type": account.get("type", ""),
 702:         })
 703:     return positions
 704: 
 705: 
 706: def place_stop_loss(
 707:     orderbook_id: str,
 708:     trigger_price: float,
 709:     sell_price: float,
 710:     volume: int,
 711:     account_id: str | None = None,
 712:     valid_days: int = 8,
 713:     trigger_type: str = "LESS_OR_EQUAL",
 714:     value_type: str = "MONETARY",
 715: ) -> dict:
 716:     """Place a hardware stop-loss order on Avanza.
 717: 
 718:     IMPORTANT: Uses /_api/trading/stoploss/new, NOT the regular order API.
 719: 
 720:     Args:
 721:         orderbook_id: Avanza orderbook ID.
 722:         trigger_price: Price at which to trigger the stop-loss.
 723:             For FOLLOW_DOWNWARDS with PERCENTAGE, this is the trail %.
 724:         sell_price: Price to sell at when triggered.
 725:             For trailing stops (FOLLOW_DOWNWARDS), set to 0 (market).
 726:         volume: Number of units to sell.
 727:         account_id: Defaults to DEFAULT_ACCOUNT_ID.
 728:         valid_days: Days until the stop-loss expires (default 8).
 729:         trigger_type: LESS_OR_EQUAL, MORE_OR_EQUAL, FOLLOW_DOWNWARDS, FOLLOW_UPWARDS.
 730:         value_type: MONETARY (absolute price) or PERCENTAGE.
 731: 
 732:     Returns:
 733:         Dict with status, stoplossOrderId.
 734:     """
 735:     acct = str(account_id or DEFAULT_ACCOUNT_ID)
 736:     if acct not in ALLOWED_ACCOUNT_IDS:
 737:         raise ValueError(f"Refusing to place stop-loss on non-whitelisted account {acct!r}")
 738:     valid_until = (date.today() + timedelta(days=valid_days)).isoformat()
 739: 
 740:     payload = {
 741:         "parentStopLossId": "0",
 742:         "accountId": acct,
 743:         "orderBookId": str(orderbook_id),
 744:         "stopLossTrigger": {
 745:             "type": trigger_type,
 746:             "value": trigger_price,
 747:             "validUntil": valid_until,
 748:             "valueType": value_type,
 749:             "triggerOnMarketMakerQuote": True,
 750:         },
 751:         "stopLossOrderEvent": {
 752:             "type": "SELL",
 753:             "price": sell_price,
 754:             "volume": volume,
 755:             "validDays": valid_days,
 756:             "priceType": value_type,
 757:             "shortSellingAllowed": False,
 758:         },
 759:     }
 760:     # 2026-04-13: cross-process order lock. Stop-loss placement is
 761:     # especially race-sensitive because cancel-before-place flows are
 762:     # common (see user memory: cancel existing stop BEFORE placing new sell).
 763:     with avanza_order_lock(op=f"place_stop_loss/{orderbook_id}"):
 764:         result = api_post("/_api/trading/stoploss/new", payload)
 765:     status = result.get("status", "UNKNOWN")
 766:     if status == "SUCCESS":
 767:         logger.info(
 768:             "Stop-loss placed: %s trigger=%.3f sell=%.3f vol=%d (id=%s)",
 769:             trigger_type, trigger_price, sell_price, volume,
 770:             result.get("stoplossOrderId", "?"),
 771:         )
 772:     else:
 773:         logger.warning("Stop-loss failed: %s — %s", status, result)
 774:     return result
 775: 
 776: 
 777: def place_trailing_stop(
 778:     orderbook_id: str,
 779:     trail_percent: float,
 780:     volume: int,
 781:     account_id: str | None = None,
 782:     valid_days: int = 8,
 783: ) -> dict:
 784:     """Place a hardware trailing stop-loss that Avanza manages automatically.
 785: 
 786:     The stop follows the price downward by trail_percent%. If the instrument
 787:     drops trail_percent% from its peak since placement, the stop triggers a
 788:     market sell.
 789: 
 790:     Args:
 791:         orderbook_id: Avanza orderbook ID.
 792:         trail_percent: Trailing distance as percentage (e.g. 5.0 for 5%).
 793:         volume: Number of units to sell.
 794:         account_id: Defaults to DEFAULT_ACCOUNT_ID.
 795:         valid_days: Days until the stop expires (default 8).
 796: 
 797:     Returns:
 798:         Dict with status, stoplossOrderId.
 799:     """
 800:     return place_stop_loss(
 801:         orderbook_id=orderbook_id,
 802:         trigger_price=trail_percent,
 803:         sell_price=0,
 804:         volume=volume,
 805:         account_id=account_id,
 806:         valid_days=valid_days,
 807:         trigger_type="FOLLOW_DOWNWARDS",
 808:         value_type="PERCENTAGE",
 809:     )
 810: 
 811: 
 812: def get_stop_losses() -> list[dict]:
 813:     """Get all active stop-loss orders.
 814: 
 815:     Returns ``[]`` on read failure for backward compatibility with
 816:     callers that treat empty as "nothing to monitor". Code that needs
 817:     to distinguish "no stops" from "could not read stops" must use
 818:     :func:`get_stop_losses_strict` instead — or a False return from
 819:     that function will leave the caller unable to make safety
 820:     decisions like cancel-before-sell.
 821:     """
 822:     try:
 823:         data = api_get("/_api/trading/stoploss")
 824:         return data if isinstance(data, list) else []
 825:     except RuntimeError:
 826:         logger.warning("Could not fetch stop-losses")
 827:         return []
 828: 
 829: 
 830: def get_stop_losses_strict() -> list[dict]:
 831:     """Get all active stop-loss orders, raising on any read failure.
 832: 
 833:     Use this in safety-critical paths (e.g., before a sell) where
 834:     "could not read" must NOT be silently treated as "no stops exist".
 835:     A swallowed read error there would let the dependent sell proceed
 836:     against still-encumbered volume, producing the very
 837:     ``short.sell.not.allowed`` error this module exists to prevent.
 838: 
 839:     Raises:
 840:         RuntimeError: if the underlying ``api_get`` call fails or
 841:             returns a non-list shape.
 842:     """
 843:     data = api_get("/_api/trading/stoploss")
 844:     if not isinstance(data, list):
 845:         raise RuntimeError(
 846:             f"Unexpected stop-loss response shape: {type(data).__name__}"
 847:         )
 848:     return data
 849: 
 850: 
 851: def cancel_stop_loss(stop_id: str, account_id: str | None = None) -> dict:
 852:     """Cancel a single stop-loss order by ID.
 853: 
 854:     Idempotent: HTTP 404 (already gone) is treated as success since the
 855:     end-state is identical from the caller's perspective.
 856: 
 857:     Uses DELETE /_api/trading/stoploss/{accountId}/{stopId}, which is the
 858:     correct endpoint per portfolio/avanza_control.py:206. Do NOT use the
 859:     regular order cancel API — it returns "crossing prices" errors for
 860:     stop-losses (March 3 incident).
 861: 
 862:     Args:
 863:         stop_id: Avanza stop-loss ID (e.g. "A2^1773297348702^1346781").
 864:         account_id: Avanza account ID. Defaults to ``DEFAULT_ACCOUNT_ID``.
 865: 
 866:     Returns:
 867:         Dict with keys ``status`` ("SUCCESS"/"FAILED"), ``http_status`` (int),
 868:         and ``stop_id`` (str). Errors that prevent the call from running
 869:         (network, missing CSRF, etc.) yield ``status="FAILED"`` with
 870:         ``http_status=0`` and an ``error`` key describing the cause.
 871:     """
 872:     if not stop_id:
 873:         return {"status": "FAILED", "http_status": 0, "stop_id": "", "error": "empty stop_id"}
 874:     acct = str(account_id or DEFAULT_ACCOUNT_ID)
 875:     try:
 876:         # 2026-04-13: cross-process order lock — SL cancel is mutating.
 877:         # See cancel_order / place_stop_loss for rationale.
 878:         with avanza_order_lock(op=f"cancel_stop_loss/{stop_id}"):
 879:             result = api_delete(f"/_api/trading/stoploss/{acct}/{stop_id}")
 880:     except Exception as exc:  # noqa: BLE001 — propagate as structured failure
 881:         logger.error("cancel_stop_loss(%s) raised: %s", stop_id, exc, exc_info=True)
 882:         return {"status": "FAILED", "http_status": 0, "stop_id": stop_id, "error": str(exc)}
 883:     http_status = int(result.get("http_status", 0)) if isinstance(result, dict) else 0
 884:     # 2xx = deleted; 404 = already gone (triggered/expired/cancelled). Both succeed.
 885:     ok = (200 <= http_status < 300) or http_status == 404
 886:     if ok:
 887:         logger.info("cancel_stop_loss(%s) -> %s", stop_id, http_status)
 888:     else:
 889:         logger.warning("cancel_stop_loss(%s) failed: http=%s result=%s", stop_id, http_status, result)
 890:     return {
 891:         "status": "SUCCESS" if ok else "FAILED",
 892:         "http_status": http_status,
 893:         "stop_id": stop_id,
 894:     }
 895: 
 896: 
 897: def cancel_all_stop_losses_for(
 898:     orderbook_id: str,
 899:     account_id: str | None = None,
 900:     max_wait: float = 3.0,
 901:     poll_interval: float = 0.5,
 902: ) -> dict:
 903:     """Cancel every active stop-loss for ``orderbook_id`` and verify clearance.
 904: 
 905:     The "verify" step is the critical part: Avanza's DELETE returns 200 OK
 906:     immediately, but the encumbered volume on the position is not released
 907:     until the SL actually disappears from the position view. Without polling,
 908:     a follow-up SELL still gets ``short.sell.not.allowed``. We therefore
 909:     re-query ``get_stop_losses_strict()`` every ``poll_interval`` seconds
 910:     until none remain for the target orderbook (or ``max_wait`` is exceeded).
 911: 
 912:     **Fail-closed semantics**: if the stop-loss list cannot be read (network
 913:     error, 5xx, malformed response), the function returns ``status="FAILED"``
 914:     rather than silently treating "could not read" as "no stops exist".
 915:     A safety-critical caller deciding whether to proceed with a sell MUST
 916:     NOT be misled into believing the path is clear when reality is unknown.
 917: 
 918:     The function is idempotent and safe to call when no SLs exist — it
 919:     short-circuits to ``status="SUCCESS"`` without any DELETE calls.
 920: 
 921:     Args:
 922:         orderbook_id: Avanza orderbook ID to clear.
 923:         account_id: Account filter. ``None`` means accept any account.
 924:         max_wait: Maximum total wall-clock seconds to wait for clearance.
 925:         poll_interval: Seconds between re-query attempts.
 926: 
 927:     Returns:
 928:         Dict with:
 929:             - ``status``: "SUCCESS" (cleared), "PARTIAL" (some cancelled, some
 930:               still showing after timeout), or "FAILED" (no cancels succeeded
 931:               and stops still present, OR the SL list could not be read).
 932:             - ``cancelled``: list of stop_ids the DELETE call accepted.
 933:             - ``remaining``: list of stop_ids still present after the wait.
 934:             - ``snapshot``: list of full stop-loss dicts that were present at
 935:               the start of the cancel sequence. Callers can use this to
 936:               **re-arm** identical stops if the dependent sell fails — the
 937:               cancel/sell sequence is otherwise rollbackable but leaves the
 938:               position naked on partial-completion failure.
 939:             - ``elapsed_seconds``: float, total time spent in this call.
 940:             - ``error``: optional, present only when ``status="FAILED"`` due
 941:               to a read error rather than cancel failures.
 942:     """
 943:     started = time.monotonic()
 944:     target_ob = str(orderbook_id)
 945:     aid_filter = str(account_id) if account_id is not None else None
 946: 
 947:     def _filter_for_ob(stops: list[dict]) -> list[dict]:
 948:         out = []
 949:         for sl in stops:
 950:             if not isinstance(sl, dict):
 951:                 continue
 952:             ob = (sl.get("orderbook") or {}).get("id")
 953:             if str(ob) != target_ob:
 954:                 continue
 955:             if aid_filter is not None:
 956:                 acct = (sl.get("account") or {}).get("id")
 957:                 if str(acct) != aid_filter:
 958:                     continue
 959:             out.append(sl)
 960:         return out
 961: 
 962:     # Initial fetch — fail closed on read errors. A safety-critical caller
 963:     # cannot tell "no stops" apart from "API down" without this distinction.
 964:     try:
 965:         all_stops = get_stop_losses_strict()
 966:     except Exception as exc:  # noqa: BLE001 — convert to structured failure
 967:         elapsed = time.monotonic() - started
 968:         logger.error(
 969:             "cancel_all_stop_losses_for(%s): cannot read stop-loss list: %s",
 970:             target_ob, exc,
 971:         )
 972:         return {
 973:             "status": "FAILED",
 974:             "cancelled": [],
 975:             "remaining": [],
 976:             "snapshot": [],
 977:             "elapsed_seconds": elapsed,
 978:             "error": f"read_error: {exc}",
 979:         }
 980: 

--- portfolio/avanza_session.py:980-1400
 980: 
 981:     initial = _filter_for_ob(all_stops)
 982:     if not initial:
 983:         return {
 984:             "status": "SUCCESS",
 985:             "cancelled": [],
 986:             "remaining": [],
 987:             "snapshot": [],
 988:             "elapsed_seconds": time.monotonic() - started,
 989:         }
 990: 
 991:     # Snapshot full dicts before cancelling so a caller can re-arm if the
 992:     # dependent sell fails downstream. We deep-copy to insulate against any
 993:     # downstream mutation of the returned structure.
 994:     import copy as _copy
 995:     snapshot = [_copy.deepcopy(sl) for sl in initial]
 996: 
 997:     # Issue cancels for every matching stop. Use the SL's own account id when
 998:     # available — Avanza's DELETE endpoint requires the account that owns the
 999:     # stop, which may differ from DEFAULT_ACCOUNT_ID for multi-account users.
1000:     cancelled: list[str] = []
1001:     for sl in initial:
1002:         sid = sl.get("id") or ""
1003:         if not sid:
1004:             continue
1005:         sl_acct = (sl.get("account") or {}).get("id") or account_id
1006:         result = cancel_stop_loss(sid, account_id=sl_acct)
1007:         if result.get("status") == "SUCCESS":
1008:             cancelled.append(sid)
1009: 
1010:     # Poll until cleared or timeout. Re-query is also fail-closed — if the
1011:     # API stops responding mid-poll, treat the orderbook as "may still have
1012:     # stops" rather than declaring victory.
1013:     remaining: list[str] = []
1014:     poll_read_failed = False
1015:     while True:
1016:         try:
1017:             poll_stops = get_stop_losses_strict()
1018:         except Exception as exc:  # noqa: BLE001
1019:             logger.warning(
1020:                 "cancel_all_stop_losses_for(%s): poll read failed: %s",
1021:                 target_ob, exc,
1022:             )
1023:             poll_read_failed = True
1024:             # We don't know if the stops are gone. Fail closed.
1025:             remaining = [sl.get("id", "") for sl in initial if sl.get("id") and sl.get("id") not in cancelled]
1026:             break
1027:         still = _filter_for_ob(poll_stops)
1028:         remaining = [s.get("id", "") for s in still if s.get("id")]
1029:         if not remaining:
1030:             break
1031:         if (time.monotonic() - started) >= max_wait:
1032:             break
1033:         time.sleep(poll_interval)
1034: 
1035:     elapsed = time.monotonic() - started
1036: 
1037:     # CODEX-7 finding 1: critical filter — a DELETE-accepted id can still
1038:     # be in `remaining` if the verification poll observed it alive
1039:     # (broker rejected the cancel late, or the DELETE was acknowledged
1040:     # but never propagated). The set we expose to callers as the
1041:     # rollback set MUST be the VERIFIED-cleared set:
1042:     #     verified = cancelled - remaining
1043:     # Re-arming a stop that is still alive would create a duplicate
1044:     # at the broker, recreating the exact over-encumbered failure mode
1045:     # this whole module exists to prevent.
1046:     remaining_set = set(remaining)
1047:     cancelled = [c for c in cancelled if c not in remaining_set]
1048: 
1049:     if not remaining and not poll_read_failed:
1050:         status = "SUCCESS"
1051:         logger.info(
1052:             "cancel_all_stop_losses_for(%s): cleared %d stops in %.2fs",
1053:             target_ob, len(cancelled), elapsed,
1054:         )
1055:     elif cancelled and not poll_read_failed:
1056:         status = "PARTIAL"
1057:         logger.warning(
1058:             "cancel_all_stop_losses_for(%s): PARTIAL — verified_cancelled=%s remaining=%s elapsed=%.2fs",
1059:             target_ob, cancelled, remaining, elapsed,
1060:         )
1061:     else:
1062:         status = "FAILED"
1063:         logger.error(
1064:             "cancel_all_stop_losses_for(%s): FAILED — cancelled=%s remaining=%s read_failed=%s",
1065:             target_ob, cancelled, remaining, poll_read_failed,
1066:         )
1067:         # When the verification poll failed, we don't actually know which
1068:         # DELETEs took effect. The list of DELETE-accepted ids is
1069:         # broker-acknowledged but NOT verified-cleared. Drop them all to
1070:         # be safe on the rollback side.
1071:         if poll_read_failed:
1072:             cancelled = []
1073:     return {
1074:         "status": status,
1075:         "cancelled": cancelled,
1076:         "remaining": remaining,
1077:         "snapshot": snapshot,
1078:         "elapsed_seconds": elapsed,
1079:     }
1080: 
1081: 
1082: def rearm_stop_losses_from_snapshot(snapshot: list[dict]) -> dict:
1083:     """Re-place stop-losses from the snapshot returned by
1084:     :func:`cancel_all_stop_losses_for`.
1085: 
1086:     Used to roll back a cancel-then-sell sequence when the sell fails:
1087:     we cancelled the stops to clear the volume, the sell didn't go through,
1088:     and the position is now naked. Re-arming restores the original
1089:     protection so we are no worse off than before the attempt.
1090: 
1091:     Notes on best-effort behavior:
1092: 
1093:     - Each re-arm is independent. If one fails, the others still try.
1094:     - The new stop-loss IDs differ from the originals — Avanza issues
1095:       fresh IDs on every place. Callers tracking IDs in local state must
1096:       replace, not deduplicate.
1097:     - ``valid_days`` is computed from the snapshot's ``trigger.validUntil``
1098:       field where present, falling back to 8 days. The trigger semantics
1099:       and price/volume are preserved exactly.
1100: 
1101:     Args:
1102:         snapshot: List of stop-loss dicts as returned in
1103:             ``cancel_all_stop_losses_for(...)["snapshot"]``.
1104: 
1105:     Returns:
1106:         Dict with:
1107:             - ``status``: "SUCCESS" (all re-armed), "PARTIAL" (some failed),
1108:               "FAILED" (none succeeded), or "SUCCESS" (snapshot was empty).
1109:             - ``rearmed``: list of new stop_ids placed.
1110:             - ``failed``: list of original stop_ids that could not be re-armed.
1111:     """
1112:     if not snapshot:
1113:         return {"status": "SUCCESS", "rearmed": [], "failed": []}
1114: 
1115:     rearmed: list[str] = []
1116:     failed: list[str] = []
1117:     today_iso = date.today()
1118: 
1119:     for sl in snapshot:
1120:         if not isinstance(sl, dict):
1121:             continue
1122:         original_id = sl.get("id", "")
1123:         try:
1124:             ob_id = (sl.get("orderbook") or {}).get("id")
1125:             account = (sl.get("account") or {}).get("id")
1126:             trigger = sl.get("trigger") or {}
1127:             order = sl.get("order") or {}
1128:             trigger_value = trigger.get("value")
1129:             trigger_type = trigger.get("type", "LESS_OR_EQUAL")
1130:             value_type = trigger.get("valueType", "MONETARY")
1131:             sell_price = order.get("price")
1132:             volume = order.get("volume")
1133: 
1134:             # Compute valid_days from validUntil if present, else default 8.
1135:             valid_days = 8
1136:             valid_until = trigger.get("validUntil")
1137:             if valid_until:
1138:                 try:
1139:                     parsed = datetime.strptime(valid_until, "%Y-%m-%d").date()
1140:                     delta = (parsed - today_iso).days
1141:                     if delta > 0:
1142:                         valid_days = delta
1143:                 except (ValueError, TypeError):
1144:                     pass
1145: 
1146:             if not (ob_id and trigger_value is not None and sell_price is not None and volume):
1147:                 logger.warning("rearm_stop_losses: snapshot entry missing fields: %s", sl)
1148:                 failed.append(original_id)
1149:                 continue
1150: 
1151:             result = place_stop_loss(
1152:                 orderbook_id=str(ob_id),
1153:                 trigger_price=float(trigger_value),
1154:                 sell_price=float(sell_price),
1155:                 volume=int(volume),
1156:                 account_id=account,
1157:                 valid_days=valid_days,
1158:                 trigger_type=str(trigger_type),
1159:                 value_type=str(value_type),
1160:             )
1161:             if result.get("status") == "SUCCESS":
1162:                 new_id = result.get("stoplossOrderId", "")
1163:                 rearmed.append(new_id)
1164:                 logger.info(
1165:                     "rearm_stop_losses: replaced %s -> %s (ob=%s vol=%s)",
1166:                     original_id, new_id, ob_id, volume,
1167:                 )
1168:             else:
1169:                 logger.warning(
1170:                     "rearm_stop_losses: place_stop_loss failed for original %s: %s",
1171:                     original_id, result,
1172:                 )
1173:                 failed.append(original_id)
1174:         except Exception as exc:  # noqa: BLE001
1175:             logger.error(
1176:                 "rearm_stop_losses: exception for original %s: %s",
1177:                 original_id, exc, exc_info=True,
1178:             )
1179:             failed.append(original_id)
1180: 
1181:     if not failed:
1182:         status = "SUCCESS"
1183:     elif rearmed:
1184:         status = "PARTIAL"
1185:     else:
1186:         status = "FAILED"
1187:     return {"status": status, "rearmed": rearmed, "failed": failed}
1188: 
1189: 
1190: def get_instrument_price(orderbook_id: str) -> dict[str, Any]:
1191:     """Get price info for a specific instrument.
