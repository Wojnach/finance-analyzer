--- portfolio/avanza_tracker.py
   1: """Avanza-tracked instruments: Nordic stocks (price-only) and warrants (underlying signals).
   2: 
   3: Tier 2 (Nordic equities): Price + P&L only via Avanza API. No technical signals.
   4: Tier 3 (Warrants): Warrant price via Avanza + underlying ticker's signals for decisions.
   5: 
   6: Configuration lives in config.json under "avanza.instruments":
   7:     {
   8:         "avanza": {
   9:             "instruments": {
  10:                 "SAAB-B": {"orderbook_id": "5533", "type": "equity", "name": "SAAB B"},
  11:                 "MINI-SILVER": {"orderbook_id": "2345", "type": "warrant", "name": "MINI L SILVER AVA 140", "underlying": "XAG-USD"}
  12:             }
  13:         }
  14:     }
  15: """
  16: 
  17: import logging
  18: from pathlib import Path
  19: from typing import Any
  20: 
  21: from portfolio.file_utils import load_json
  22: 
  23: logger = logging.getLogger("portfolio.avanza_tracker")
  24: 
  25: BASE_DIR = Path(__file__).resolve().parent.parent
  26: CONFIG_FILE = BASE_DIR / "config.json"
  27: 
  28: 
  29: def load_avanza_instruments() -> dict[str, dict]:
  30:     """Load Avanza instrument config from config.json.
  31: 
  32:     Returns:
  33:         Dict of {config_key: instrument_config} or empty dict if not configured.
  34:     """
  35:     config = load_json(CONFIG_FILE, default={})
  36:     if not config:
  37:         return {}
  38:     return config.get("avanza", {}).get("instruments", {})
  39: 
  40: 
  41: def fetch_avanza_prices() -> dict[str, dict[str, Any]]:
  42:     """Fetch current prices for all configured Avanza instruments.
  43: 
  44:     Returns:
  45:         Dict of {config_key: {"name": str, "price_sek": float, "change_pct": float, "type": str}}
  46:         Skips instruments with missing or empty orderbook_id.
  47:     """
  48:     instruments = load_avanza_instruments()
  49:     if not instruments:
  50:         return {}
  51: 
  52:     try:
  53:         from portfolio.avanza_client import get_price
  54:     except Exception as e:
  55:         logger.debug("avanza_client not available: %s", e)
  56:         return {}
  57: 
  58:     results = {}
  59:     for key, cfg in instruments.items():
  60:         ob_id = cfg.get("orderbook_id", "")
  61:         if not ob_id:
  62:             continue
  63:         try:
  64:             info = get_price(ob_id)
  65:             results[key] = {
  66:                 "name": cfg.get("name", key),
  67:                 "price_sek": float(info.get("lastPrice", 0)),
  68:                 "change_pct": float(info.get("changePercent", 0)),
  69:                 "type": cfg.get("type", "equity"),
  70:                 "underlying": cfg.get("underlying"),
  71:             }
  72:         except Exception as e:
  73:             logger.warning("Price fetch failed for %s: %s", key, e)
  74:     return results
  75: 
  76: 
  77: def get_warrant_underlying(config_key: str) -> str | None:
  78:     """Get the underlying ticker for a warrant instrument.
  79: 
  80:     Args:
  81:         config_key: The config key (e.g., "MINI-SILVER")
  82: 
  83:     Returns:
  84:         Underlying ticker (e.g., "XAG-USD") or None if not a warrant.
  85:     """
  86:     instruments = load_avanza_instruments()
  87:     cfg = instruments.get(config_key, {})
  88:     if cfg.get("type") != "warrant":
  89:         return None
  90:     return cfg.get("underlying")
  91: 
  92: 
  93: def get_all_underlyings() -> dict[str, str]:
  94:     """Get mapping of all warrant config keys to their underlying tickers.
  95: 
  96:     Returns:
  97:         Dict of {config_key: underlying_ticker} for all warrants.
  98:     """
  99:     instruments = load_avanza_instruments()
 100:     return {
 101:         key: cfg["underlying"]
 102:         for key, cfg in instruments.items()
 103:         if cfg.get("type") == "warrant" and cfg.get("underlying")
 104:     }
 105: 
 106: 
 107: def check_session_expiry() -> str | None:
 108:     """Check if Avanza BankID session is expired or expiring soon.
 109: 
 110:     Returns:
 111:         Warning message string if session needs refresh, None if OK.
 112:     """
 113:     try:
 114:         from portfolio.avanza_session import (
 115:             is_session_expiring_soon,
 116:             session_remaining_minutes,
 117:         )
 118:     except ImportError:
 119:         return None
 120: 
 121:     remaining = session_remaining_minutes()
 122:     if remaining is None:
 123:         return "Avanza session not found. Run: python scripts/avanza_login.py"
 124:     if remaining <= 0:
 125:         return "Avanza session expired. Run: python scripts/avanza_login.py"
 126:     if is_session_expiring_soon(threshold_minutes=60.0):
 127:         mins = int(remaining)
 128:         return (
 129:             f"Avanza session expires in {mins}min. "
 130:             "Run: python scripts/avanza_login.py"
 131:         )
 132:     return None

--- portfolio/avanza_client.py
   1: """Avanza API client for portfolio monitoring and trading.
   2: 
   3: Supports two authentication methods:
   4: 1. BankID session (preferred) — captured by scripts/avanza_login.py, stored in
   5:    data/avanza_session.json. No credentials needed, valid ~24h.
   6: 2. TOTP credentials (fallback) — uses avanza-api library with username/password/TOTP
   7:    from config.json.
   8: 
   9: The client transparently tries BankID session first, then falls back to TOTP.
  10: """
  11: 
  12: import logging
  13: from datetime import date
  14: from pathlib import Path
  15: from typing import Any
  16: 
  17: from portfolio.file_utils import load_json
  18: 
  19: logger = logging.getLogger("portfolio.avanza_client")
  20: 
  21: BASE_DIR = Path(__file__).resolve().parent.parent
  22: CONFIG_FILE = BASE_DIR / "config.json"
  23: 
  24: # A-AV-2 (2026-04-11): Hardcoded account whitelist. The TOTP path scans for
  25: # any account whose accountType contains "ISK", which means a future Avanza
  26: # response containing a *new* ISK-shaped account (e.g. a child's ISK or a
  27: # corporate ISK) could be picked up as the trading account. Worse, the
  28: # pension account (2674244) was previously reachable through some code paths
  29: # without filtering. Mirror the ALLOWED_ACCOUNT_IDS pattern from
  30: # avanza_session.py: anything not in this set is rejected, period.
  31: ALLOWED_ACCOUNT_IDS: set[str] = {"1625505"}
  32: 
  33: # Singleton client instance (avanza-api library)
  34: _client = None
  35: # Cached signal that a BankID Playwright session has already been verified.
  36: _session_client = None
  37: 
  38: 
  39: def _load_credentials() -> dict:
  40:     """Load Avanza credentials from config.json.
  41: 
  42:     Returns:
  43:         dict with keys: username, password, totp_secret
  44: 
  45:     Raises:
  46:         FileNotFoundError: if config.json does not exist
  47:         KeyError: if 'avanza' section is missing or credentials incomplete
  48:     """
  49:     config = load_json(CONFIG_FILE)
  50:     if config is None:
  51:         raise FileNotFoundError(f"Config file not found or unreadable: {CONFIG_FILE}")
  52:     if "avanza" not in config:
  53:         raise KeyError(
  54:             "Missing 'avanza' section in config.json. "
  55:             "Add: {\"avanza\": {\"username\": \"...\", \"password\": \"...\", \"totp_secret\": \"...\"}}"
  56:         )
  57:     creds = config["avanza"]
  58:     for key in ("username", "password", "totp_secret"):
  59:         if key not in creds or not creds[key]:
  60:             raise KeyError(f"Missing or empty 'avanza.{key}' in config.json")
  61:     return creds
  62: 
  63: 
  64: def _try_session_auth() -> bool:
  65:     """Return True when a BankID-backed Playwright session is available."""
  66:     global _session_client
  67:     if _session_client is True:
  68:         return True
  69:     try:
  70:         from portfolio.avanza_session import verify_session
  71:         if verify_session():
  72:             _session_client = True
  73:             logger.info("Using BankID session for Avanza API")
  74:             return True
  75:         logger.info("BankID session exists but verification failed")
  76:     except Exception as e:
  77:         logger.debug("BankID session not available: %s", e)
  78:     return False
  79: 
  80: 
  81: def get_client():
  82:     """Get or create a singleton Avanza client.
  83: 
  84:     Tries BankID session first, then falls back to TOTP credentials.
  85: 
  86:     Returns:
  87:         Authenticated Avanza client instance (avanza-api library)
  88: 
  89:     Raises:
  90:         Exception: if neither auth method works
  91:     """
  92:     global _client
  93:     if _client is not None:
  94:         return _client
  95:     try:
  96:         from avanza import Avanza
  97:     except ImportError:
  98:         raise ImportError(
  99:             "avanza-api package not installed. Run: pip install avanza-api"
 100:         ) from None
 101:     creds = _load_credentials()
 102:     _client = Avanza({
 103:         "username": creds["username"],
 104:         "password": creds["password"],
 105:         "totpSecret": creds["totp_secret"],
 106:     })
 107:     return _client
 108: 
 109: 
 110: def reset_client() -> None:
 111:     """Reset the singleton TOTP client (useful for re-authentication)."""
 112:     global _client
 113:     _client = None
 114: 
 115: 
 116: def reset_session() -> None:
 117:     """Reset the cached BankID session verification flag."""
 118:     global _session_client
 119:     _session_client = None
 120: 
 121: 
 122: def find_instrument(query: str) -> list[dict]:
 123:     """Search for instruments by name or ticker.
 124: 
 125:     Args:
 126:         query: Search string (e.g., 'Bitcoin', 'NVDA', 'Silver')
 127: 
 128:     Returns:
 129:         List of matching instruments with id, name, and type
 130:     """
 131:     client = get_client()
 132:     results = client.search_for_stock(query)
 133:     return results
 134: 
 135: 
 136: def get_price(orderbook_id: str) -> dict[str, Any]:
 137:     """Get current price and info for an instrument.
 138: 
 139:     Tries BankID session first, then falls back to TOTP client.
 140: 
 141:     Args:
 142:         orderbook_id: Avanza orderbook ID (numeric string)
 143: 
 144:     Returns:
 145:         Dict with price info including lastPrice, change, changePercent, etc.
 146:     """
 147:     # Try session-based auth first
 148:     if _try_session_auth():
 149:         try:
 150:             from portfolio.avanza_session import get_instrument_price
 151:             return get_instrument_price(orderbook_id)
 152:         except Exception as e:
 153:             logger.warning("Session-based price fetch failed, trying TOTP: %s", e)
 154:             reset_session()
 155: 
 156:     client = get_client()
 157:     info = client.get_stock_info(orderbook_id)
 158:     return info
 159: 
 160: 
 161: def get_positions() -> list[dict]:
 162:     """Get all current positions from the Avanza account.
 163: 
 164:     Tries BankID session first, then falls back to TOTP client.
 165: 
 166:     Returns:
 167:         List of position dicts, each with name, value, profit, etc.
 168:         Returns empty list if no positions or on error.
 169:     """
 170:     # Try session-based auth first
 171:     if _try_session_auth():
 172:         try:
 173:             from portfolio.avanza_session import get_positions as session_get_positions
 174:             return session_get_positions()
 175:         except Exception as e:
 176:             logger.warning("Session-based positions fetch failed, trying TOTP: %s", e)
 177:             reset_session()
 178: 
 179:     client = get_client()
 180:     overview = client.get_overview()
 181:     positions = []
 182:     # A-AV-2: only return positions from whitelisted accounts so the pension
 183:     # account (or any future-added account) never leaks into the trading view.
 184:     for account in overview.get("accounts", []):
 185:         if str(account.get("accountId", "")) not in ALLOWED_ACCOUNT_IDS:
 186:             continue
 187:         for pos in account.get("positions", []):
 188:             positions.append({
 189:                 "account": account.get("name", ""),
 190:                 "account_id": account.get("accountId", ""),
 191:                 "name": pos.get("name", ""),
 192:                 "ticker": pos.get("orderbookId", ""),
 193:                 "volume": pos.get("volume", 0),
 194:                 "value": pos.get("value", 0),
 195:                 "profit": pos.get("profit", 0),
 196:                 "profit_percent": pos.get("profitPercent", 0),
 197:                 "currency": pos.get("currency", "SEK"),
 198:             })
 199:     return positions
 200: 
 201: 
 202: def get_portfolio_value() -> float:
 203:     """Get total portfolio value in SEK for whitelisted Avanza accounts only.
 204: 
 205:     A-AV-2: Filters to ALLOWED_ACCOUNT_IDS so pension/other-account values
 206:     never inflate the "trading" portfolio value used for sizing.
 207: 
 208:     Returns:
 209:         Total portfolio value in SEK across whitelisted accounts
 210:     """
 211:     client = get_client()
 212:     overview = client.get_overview()
 213:     total = 0.0
 214:     for account in overview.get("accounts", []):
 215:         if str(account.get("accountId", "")) not in ALLOWED_ACCOUNT_IDS:
 216:             continue
 217:         total += account.get("totalValue", 0)
 218:     return total
 219: 
 220: 
 221: def get_open_orders() -> list:
 222:     """Return open orders for the ISK account (read-only).
 223: 
 224:     Uses the authenticated Avanza client; does not place or cancel orders.
 225:     """
 226:     client = get_client()
 227:     account_id = get_account_id()
 228:     try:
 229:         orders = client.get_orders(account_id)
 230:     except Exception as e:
 231:         logger.error("Failed to fetch open orders: %s", e)
 232:         raise
 233:     return orders or []
 234: 
 235: 
 236: # --- Account ID ---
 237: 
 238: _account_id: str | None = None
 239: 
 240: 
 241: def get_account_id() -> str:
 242:     """Get the trading account ID from Avanza overview (cached).
 243: 
 244:     Scans accounts of type ISK and returns the first one *that is also in
 245:     ALLOWED_ACCOUNT_IDS*. Any ISK account not in the whitelist is rejected.
 246:     This prevents accidental trades on a future-added child ISK, corporate
 247:     ISK, or any account Avanza re-orders into the response.
 248: 
 249:     Returns:
 250:         Account ID string (guaranteed to be in ALLOWED_ACCOUNT_IDS)
 251: 
 252:     Raises:
 253:         RuntimeError: if no whitelisted ISK account is found
 254:     """
 255:     global _account_id
 256:     if _account_id is not None:
 257:         return _account_id
 258:     client = get_client()
 259:     overview = client.get_overview()
 260:     seen_ids: list[str] = []

--- portfolio/avanza_control.py
   1: """Canonical Avanza control facade for reads, quotes, and browser-session trades.
   2: 
   3: Use this module as the shared import path for Avanza operations in strategy code.
   4: It keeps the currently working Playwright-page execution path for metals/gold
   5: while exposing the broader account/session helpers from ``portfolio.avanza_*``.
   6: """
   7: 
   8: from __future__ import annotations
   9: 
  10: import json
  11: import logging
  12: 
  13: from portfolio.avanza_order_lock import avanza_order_lock
  14: 
  15: logger = logging.getLogger("portfolio.avanza_control")
  16: 
  17: from data.metals_avanza_helpers import (
  18:     check_session_alive,
  19:     get_csrf,
  20: )
  21: from data.metals_avanza_helpers import (
  22:     fetch_account_cash as _fetch_account_cash,
  23: )
  24: from data.metals_avanza_helpers import (
  25:     fetch_positions as _fetch_page_positions,
  26: )
  27: from data.metals_avanza_helpers import (
  28:     fetch_price as _fetch_page_price,
  29: )
  30: from data.metals_avanza_helpers import (
  31:     place_order as _place_page_order,
  32: )
  33: from data.metals_avanza_helpers import (
  34:     place_stop_loss as _place_page_stop_loss,
  35: )
  36: from portfolio.avanza_client import (
  37:     delete_order,
  38:     find_instrument,
  39:     get_account_id,
  40:     get_open_orders,
  41:     get_portfolio_value,
  42:     get_positions,
  43:     place_buy_order,
  44:     place_sell_order,
  45: )
  46: from portfolio.avanza_client import (
  47:     get_price as get_price_info,
  48: )
  49: 
  50: _TYPE_ALIASES = {
  51:     "cert": "certificate",
  52:     "certifikat": "certificate",
  53:     "certificate": "certificate",
  54:     "warrant": "warrant",
  55:     "mini": "warrant",
  56:     "mini-future": "warrant",
  57:     "mini_future": "warrant",
  58:     "stock": "stock",
  59:     "share": "stock",
  60:     "fund": "fund",
  61:     "etf": "exchange_traded_fund",
  62:     "exchange_traded_fund": "exchange_traded_fund",
  63: }
  64: 
  65: _PRICE_FALLBACK_TYPES = (
  66:     "certificate",
  67:     "warrant",
  68:     "stock",
  69:     "exchange_traded_fund",
  70:     "fund",
  71: )
  72: 
  73: 
  74: def normalize_api_type(api_type: str | None, default: str = "certificate") -> str:
  75:     """Normalize Avanza instrument type names for market-guide lookups."""
  76:     normalized = (api_type or "").strip().lower()
  77:     if not normalized:
  78:         return default
  79:     return _TYPE_ALIASES.get(normalized, normalized)
  80: 
  81: 
  82: def fetch_price(page, orderbook_id: str, api_type: str = "certificate"):
  83:     """Fetch a quote from the market-guide API using an authenticated page."""
  84:     return _fetch_page_price(page, orderbook_id, normalize_api_type(api_type))
  85: 
  86: 
  87: def fetch_price_with_fallback(page, orderbook_id: str, api_type: str | None = None):
  88:     """Try the preferred market-guide type and then the common fallback types."""
  89:     if not orderbook_id:
  90:         return None
  91: 
  92:     candidates: list[str] = []
  93:     preferred = normalize_api_type(api_type) if api_type else ""
  94:     if preferred:
  95:         candidates.append(preferred)
  96:     for fallback in _PRICE_FALLBACK_TYPES:
  97:         if fallback not in candidates:
  98:             candidates.append(fallback)
  99: 
 100:     for candidate in candidates:
 101:         data = fetch_price(page, orderbook_id, candidate)
 102:         if not data:
 103:             continue
 104:         if data.get("bid") is None and data.get("ask") is None and data.get("last") is None:
 105:             continue
 106:         payload = dict(data)
 107:         payload["api_type"] = candidate
 108:         return payload
 109:     return None
 110: 
 111: 
 112: def fetch_account_cash(page, account_id: str | None = None):
 113:     """Fetch buying power for an account via the authenticated browser session."""
 114:     resolved_account_id = str(account_id or get_account_id())
 115:     return _fetch_account_cash(page, resolved_account_id)
 116: 
 117: 
 118: def fetch_page_positions(page, account_id: str | None = None):
 119:     """Fetch current positions keyed by orderbook id via the page session.
 120: 
 121:     Returns dict[ob_id -> {name, units, value, avg_price, api_type}] on
 122:     success, or None on transient failure. An empty dict `{}` is a valid
 123:     response meaning the account is flat — callers should distinguish it
 124:     from None.
 125:     """
 126:     resolved_account_id = str(account_id or get_account_id())
 127:     return _fetch_page_positions(page, resolved_account_id)
 128: 
 129: 
 130: def place_order(page, account_id: str | None, ob_id: str, side: str, price: float, volume: int):
 131:     """Place a BUY/SELL order via the authenticated browser session."""
 132:     resolved_account_id = str(account_id or get_account_id())
 133:     normalized_side = (side or "").strip().upper()
 134:     return _place_page_order(page, resolved_account_id, ob_id, normalized_side, price, volume)
 135: 
 136: 
 137: def place_stop_loss(
 138:     page,
 139:     account_id: str | None,
 140:     ob_id: str,
 141:     trigger_price: float,
 142:     sell_price: float,
 143:     volume: int,
 144:     valid_days: int = 8,
 145: ):
 146:     """Place a hardware stop-loss order via the authenticated browser session."""
 147:     resolved_account_id = str(account_id or get_account_id())
 148:     return _place_page_stop_loss(
 149:         page,
 150:         resolved_account_id,
 151:         ob_id,
 152:         trigger_price,
 153:         sell_price,
 154:         volume,
 155:         valid_days=valid_days,
 156:     )
 157: 
 158: 
 159: def delete_order_live(page, account_id: str | None, order_id: str):
 160:     """Cancel an open order via the authenticated page session.
 161: 
 162:     IMPORTANT: Uses POST to /_api/trading-critical/rest/order/delete with
 163:     JSON body {accountId, orderId}. The DELETE HTTP verb to
 164:     /_api/trading-critical/rest/order/{accountId}/{orderId} returns 404
 165:     (Avanza API change discovered 2026-03-24).
 166:     """
 167:     csrf = get_csrf(page)
 168:     if not csrf:
 169:         return False, {"error": "no CSRF token"}
 170: 
 171:     resolved_account_id = str(account_id or get_account_id())
 172:     try:
 173:         # 2026-04-13: cross-process order lock (see metals_avanza_helpers.place_order).
 174:         with avanza_order_lock(op=f"delete_order_live/{order_id}"):
 175:             result = page.evaluate(
 176:                 """async (args) => {
 177:                     const [accountId, orderId, token] = args;
 178:                     const resp = await fetch(
 179:                         'https://www.avanza.se/_api/trading-critical/rest/order/delete',
 180:                         {
 181:                             method: 'POST',
 182:                             headers: {
 183:                                 'Content-Type': 'application/json',
 184:                                 'X-SecurityToken': token,
 185:                             },
 186:                             credentials: 'include',
 187:                             body: JSON.stringify({accountId: accountId, orderId: orderId}),
 188:                         }
 189:                     );
 190:                     return {status: resp.status, body: await resp.text()};
 191:                 }""",
 192:                 [resolved_account_id, order_id, csrf],
 193:             )
 194:         http_status = int(result.get("status") or 0)
 195:         body_text = result.get("body", "")
 196:         parsed = {}
 197:         try:
 198:             if body_text:
 199:                 parsed = json.loads(body_text)
 200:         except (TypeError, json.JSONDecodeError):
 201:             parsed = {}
 202:         success = parsed.get("orderRequestStatus") == "SUCCESS"
 203:         return success, {
 204:             "http_status": http_status,
 205:             "parsed": parsed,
 206:             "body": body_text,
 207:         }
 208:     except Exception as exc:
 209:         logger.error("Delete order failed for order %s: %s", order_id, exc, exc_info=True)
 210:         return False, {"error": str(exc)}
 211: 
 212: 
 213: def delete_stop_loss(page, account_id: str | None, stop_id: str):
 214:     """Delete an existing Avanza stop-loss order via the authenticated page."""
 215:     csrf = get_csrf(page)
 216:     if not csrf:
 217:         return False, {"error": "no CSRF token"}
 218: 
 219:     resolved_account_id = str(account_id or get_account_id())
 220:     try:
 221:         # 2026-04-13: cross-process order lock. SL delete is mutating.
 222:         with avanza_order_lock(op=f"delete_stop_loss/{stop_id}"):
 223:             result = page.evaluate(
 224:                 """async (args) => {
 225:                     const [accountId, stopId, token] = args;
 226:                     const resp = await fetch(
 227:                         'https://www.avanza.se/_api/trading/stoploss/' + accountId + '/' + stopId,
 228:                         {
 229:                             method: 'DELETE',
 230:                             headers: {'X-SecurityToken': token},
 231:                             credentials: 'include',
 232:                         }
 233:                     );
 234:                     return {status: resp.status, body: await resp.text()};
 235:                 }""",
 236:                 [resolved_account_id, stop_id, csrf],
 237:             )
 238:         http_status = int(result.get("status") or 0)
 239:         # 2xx = deleted successfully.  404 = stop already gone (triggered/expired/cancelled).
 240:         # Both mean the stop no longer exists, which is the goal of a cancel.
 241:         success = (200 <= http_status < 300) or http_status == 404
 242:         body_text = result.get("body", "")
 243:         parsed = {}
 244:         try:
 245:             if body_text:
 246:                 parsed = json.loads(body_text)
 247:         except (TypeError, json.JSONDecodeError):
 248:             parsed = {}
 249:         return success, {
 250:             "http_status": http_status,
 251:             "parsed": parsed,
 252:             "body": body_text,
 253:         }
 254:     except Exception as exc:
 255:         logger.error("Delete stop-loss failed for stop %s: %s", stop_id, exc, exc_info=True)
 256:         return False, {"error": str(exc)}
 257: 
 258: 
 259: 
 260: # --- Page-free API (uses BankID session, no Playwright page needed) ---

--- portfolio/avanza_order_lock.py
   1: """Cross-process advisory file lock guarding Avanza order placement.
   2: 
   3: Used across metals_loop, golddigger, fin_snipe_manager (and any future
   4: Avanza-bound loop) to prevent two processes submitting overlapping orders
   5: when they observe the same ``buying_power`` simultaneously. Without this,
   6: the following sequence is possible:
   7: 
   8:     t=0.00  metals_loop reads buying_power=6000 SEK
   9:     t=0.05  golddigger reads buying_power=6000 SEK
  10:     t=0.10  metals_loop POSTs order for 5000 SEK
  11:     t=0.15  golddigger POSTs order for 5000 SEK
  12:     t=0.20  Avanza rejects one / or both fill and settlement overdraws
  13: 
  14: READ paths (``fetch_price``, ``fetch_positions``, ``buying_power``) are
  15: NOT guarded — they're safe to run concurrently, and the whole point of
  16: the resilience refactor is to keep those fast.
  17: 
  18: Usage:
  19: 
  20:     from portfolio.avanza_order_lock import avanza_order_lock
  21: 
  22:     with avanza_order_lock(op="place_order"):
  23:         resp = api_post("/_api/trading-critical/rest/order/new", payload)
  24: 
  25: Design notes:
  26: 
  27: * ``filelock.FileLock`` is already in requirements (3.20.3 as of 2026-04-13).
  28: * 2-second fail-fast default — long enough to ride through a normal order
  29:   round-trip (~300ms), short enough that a hung peer doesn't block trading.
  30: * Raises ``OrderLockBusyError`` on timeout so callers can log + retry next
  31:   cycle instead of blocking the whole loop.
  32: * Caller-provided ``op`` label threads through to log messages for
  33:   diagnostics ("which loop hit the busy lock").
  34: """
  35: 
  36: from __future__ import annotations
  37: 
  38: import logging
  39: from collections.abc import Iterator
  40: from contextlib import contextmanager
  41: from pathlib import Path
  42: 
  43: import filelock
  44: 
  45: logger = logging.getLogger("portfolio.avanza_order_lock")
  46: 
  47: BASE_DIR = Path(__file__).resolve().parent.parent
  48: DATA_DIR = BASE_DIR / "data"
  49: LOCK_FILE = DATA_DIR / "avanza_order.lock"
  50: 
  51: DEFAULT_TIMEOUT_S = 2.0
  52: 
  53: 
  54: class OrderLockBusyError(Exception):
  55:     """Another process held the lock longer than the configured timeout."""
  56: 
  57: 
  58: @contextmanager
  59: def avanza_order_lock(
  60:     *,
  61:     timeout_s: float = DEFAULT_TIMEOUT_S,
  62:     op: str = "order",
  63:     lock_file: Path | None = None,
  64: ) -> Iterator[filelock.FileLock]:
  65:     """Acquire the cross-process Avanza order lock for a short critical section.
  66: 
  67:     Fail-fast after ``timeout_s``. The lock is released automatically on exit.
  68: 
  69:     Args:
  70:         timeout_s: Seconds to wait for the lock before raising
  71:             :class:`OrderLockBusyError`. Default 2.0 — short enough to abort
  72:             a stuck caller, long enough to ride through a normal order RTT.
  73:         op: Short label for the operation, threaded into log messages.
  74:         lock_file: Override the lock path (tests only). Defaults to
  75:             ``data/avanza_order.lock``.
  76: 
  77:     Raises:
  78:         OrderLockBusyError: If another process held the lock longer than
  79:             ``timeout_s`` seconds.
  80:     """
  81:     target = Path(lock_file) if lock_file is not None else LOCK_FILE
  82:     target.parent.mkdir(parents=True, exist_ok=True)
  83:     lock = filelock.FileLock(str(target), timeout=timeout_s)
  84:     try:
  85:         lock.acquire()
  86:     except filelock.Timeout as exc:
  87:         logger.warning(
  88:             "avanza_order_lock(%s): busy after %.1fs — another process holds the lock",
  89:             op, timeout_s,
  90:         )
  91:         raise OrderLockBusyError(f"lock busy after {timeout_s}s (op={op})") from exc
  92:     try:
  93:         logger.debug("avanza_order_lock(%s): acquired", op)
  94:         yield lock
  95:     finally:
  96:         try:
  97:             lock.release()
  98:             logger.debug("avanza_order_lock(%s): released", op)
  99:         except Exception as exc:
 100:             logger.warning("avanza_order_lock(%s): release failed: %s", op, exc)

--- portfolio/avanza_orders.py
   1: """Avanza order confirmation flow — human-in-the-loop for real money.
   2: 
   3: Workflow:
   4: 1. Layer 2 calls request_order() → saves intent to pending orders, returns details
   5: 2. Layer 2 sends Telegram message with order details + "Reply CONFIRM to execute"
   6: 3. Main loop calls check_pending_orders() each cycle
   7: 4. On CONFIRM reply → execute order via avanza_control, notify via Telegram
   8: 5. On timeout (5 min) → expire the pending order, notify
   9: """
  10: 
  11: import contextlib
  12: import logging
  13: import uuid
  14: from datetime import UTC, datetime, timedelta
  15: from pathlib import Path
  16: 
  17: from portfolio.avanza_control import place_buy_order, place_sell_order
  18: from portfolio.file_utils import atomic_write_json, load_json
  19: from portfolio.http_retry import fetch_with_retry
  20: from portfolio.telegram_notifications import send_telegram
  21: 
  22: logger = logging.getLogger("portfolio.avanza_orders")
  23: 
  24: DATA_DIR = Path(__file__).resolve().parent.parent / "data"
  25: PENDING_FILE = DATA_DIR / "avanza_pending_orders.json"
  26: EXPIRY_MINUTES = 5
  27: 
  28: 
  29: def _load_pending() -> list[dict]:
  30:     """Load pending orders from disk."""
  31:     result = load_json(PENDING_FILE, default=[])
  32:     if result is None:
  33:         logger.warning("Failed to read pending orders, returning empty")
  34:         return []
  35:     return result
  36: 
  37: 
  38: def _save_pending(orders: list[dict]) -> None:
  39:     """Save pending orders to disk atomically."""
  40:     atomic_write_json(PENDING_FILE, orders)
  41: 
  42: 
  43: def request_order(
  44:     action: str,
  45:     orderbook_id: str,
  46:     instrument_name: str,
  47:     config_key: str,
  48:     volume: int,
  49:     price: float,
  50: ) -> dict:
  51:     """Create a pending order awaiting Telegram confirmation.
  52: 
  53:     Args:
  54:         action: "BUY" or "SELL"
  55:         orderbook_id: Avanza orderbook ID
  56:         instrument_name: Human-readable name (e.g. "SAAB B")
  57:         config_key: Config key (e.g. "SAAB-B")
  58:         volume: Number of shares
  59:         price: Limit price in SEK
  60: 
  61:     Returns:
  62:         The pending order dict (includes id, total_sek, expires)
  63:     """
  64:     if action not in ("BUY", "SELL"):
  65:         raise ValueError(f"action must be BUY or SELL, got {action!r}")
  66:     if volume < 1:
  67:         raise ValueError(f"volume must be >= 1, got {volume}")
  68:     if price <= 0:
  69:         raise ValueError(f"price must be > 0, got {price}")
  70: 
  71:     now = datetime.now(UTC)
  72:     order = {
  73:         "id": str(uuid.uuid4()),
  74:         "timestamp": now.isoformat(),
  75:         "action": action,
  76:         "orderbook_id": str(orderbook_id),
  77:         "instrument_name": instrument_name,
  78:         "config_key": config_key,
  79:         "volume": volume,
  80:         "price": price,
  81:         "total_sek": round(volume * price, 2),
  82:         "status": "pending_confirmation",
  83:         "expires": (now + timedelta(minutes=EXPIRY_MINUTES)).isoformat(),
  84:     }
  85: 
  86:     pending = _load_pending()
  87:     pending.append(order)
  88:     _save_pending(pending)
  89:     logger.info("Order requested: %s %dx %s @ %.2f SEK (id=%s)",
  90:                 action, volume, instrument_name, price, order["id"])
  91:     return order
  92: 
  93: 
  94: def get_pending_orders() -> list[dict]:
  95:     """Get all orders with status 'pending_confirmation'."""
  96:     return [o for o in _load_pending() if o["status"] == "pending_confirmation"]
  97: 
  98: 
  99: def check_pending_orders(config: dict) -> list[dict]:
 100:     """Check for Telegram confirmations and expire stale orders.
 101: 
 102:     Called by the main loop each cycle. Polls Telegram getUpdates for
 103:     CONFIRM replies. Executes confirmed orders and expires timed-out ones.
 104: 
 105:     Args:
 106:         config: App config dict (with telegram.token, telegram.chat_id)
 107: 
 108:     Returns:
 109:         List of orders that were acted on (confirmed or expired) this cycle
 110:     """
 111:     pending = _load_pending()
 112:     if not pending:
 113:         return []
 114: 
 115:     acted_on = []
 116:     now = datetime.now(UTC)
 117: 
 118:     # Check for CONFIRM replies in Telegram
 119:     confirmed = _check_telegram_confirm(config)
 120: 
 121:     # Sort by timestamp descending so CONFIRM matches the most recent pending order
 122:     pending_sorted = sorted(pending, key=lambda o: o.get("timestamp", ""), reverse=True)
 123: 
 124:     for order in pending_sorted:
 125:         if order["status"] != "pending_confirmation":
 126:             continue
 127: 
 128:         expires = datetime.fromisoformat(order["expires"])
 129: 
 130:         if confirmed:
 131:             # Confirm the most recent pending order
 132:             order["status"] = "confirmed"
 133:             acted_on.append(order)
 134:             confirmed = False  # One CONFIRM per order
 135:             _execute_confirmed_order(order, config)
 136: 
 137:         elif now > expires:
 138:             order["status"] = "expired"
 139:             acted_on.append(order)
 140:             _notify_expired(order, config)
 141: 
 142:     _save_pending(pending)
 143:     return acted_on
 144: 
 145: 
 146: def _check_telegram_confirm(config: dict) -> bool:
 147:     """Poll Telegram for a CONFIRM reply from the configured chat.
 148: 
 149:     Uses getUpdates with a stored offset to avoid reprocessing old messages.
 150:     """
 151:     token = config.get("telegram", {}).get("token", "")
 152:     chat_id = str(config.get("telegram", {}).get("chat_id", ""))
 153:     if not token or not chat_id:
 154:         return False
 155: 
 156:     # Load stored offset (BUG-128: now atomic JSON; handles legacy plain-text format)
 157:     offset_file = DATA_DIR / "avanza_telegram_offset.txt"
 158:     offset = 0
 159:     offset_data = load_json(offset_file)
 160:     if isinstance(offset_data, dict):
 161:         offset = int(offset_data.get("offset", 0))
 162:     elif offset_file.exists():
 163:         with contextlib.suppress(ValueError, OSError):
 164:             offset = int(offset_file.read_text().strip())
 165: 
 166:     params = {"timeout": 1, "allowed_updates": ["message"]}
 167:     if offset:
 168:         params["offset"] = offset
 169: 
 170:     try:
 171:         r = fetch_with_retry(
 172:             f"https://api.telegram.org/bot{token}/getUpdates",
 173:             params=params,
 174:             timeout=5,
 175:         )
 176:         if r is None or not r.ok:
 177:             return False
 178:         data = r.json()
 179:         if not data.get("ok"):
 180:             return False
 181:     except Exception as e:
 182:         logger.warning("Telegram getUpdates failed: %s", e)
 183:         return False
 184: 
 185:     found_confirm = False
 186:     for update in data.get("result", []):
 187:         update_id = update.get("update_id", 0)
 188:         # Always advance offset
 189:         if update_id >= offset:
 190:             offset = update_id + 1
 191: 
 192:         msg = update.get("message", {})
 193:         if str(msg.get("chat", {}).get("id")) != chat_id:
 194:             continue
 195: 
 196:         text = (msg.get("text") or "").strip().upper()
 197:         if text == "CONFIRM":
 198:             found_confirm = True
 199: 
 200:     # Save offset atomically to prevent corruption on crash (BUG-128)
 201:     try:
 202:         atomic_write_json(offset_file, {"offset": offset})
 203:     except OSError as e:
 204:         logger.warning("Failed to save Telegram offset: %s", e)
 205: 
 206:     return found_confirm
 207: 
 208: 
 209: def _execute_confirmed_order(order: dict, config: dict) -> None:
 210:     """Execute a confirmed order on Avanza and notify via Telegram."""
 211:     action = order["action"]
 212:     try:
 213:         if action == "BUY":
 214:             result = place_buy_order(
 215:                 orderbook_id=order["orderbook_id"],
 216:                 price=order["price"],
 217:                 volume=order["volume"],
 218:             )
 219:         else:
 220:             result = place_sell_order(
 221:                 orderbook_id=order["orderbook_id"],
 222:                 price=order["price"],
 223:                 volume=order["volume"],
 224:             )
 225: 
 226:         status = result.get("orderRequestStatus", "UNKNOWN")
 227:         order_id = result.get("orderId", "?")
 228:         msg_text = result.get("message", "")
 229: 
 230:         if status == "SUCCESS":
 231:             order["status"] = "executed"
 232:             order["avanza_order_id"] = order_id
 233:             msg = (
 234:                 f"AVANZA {action} EXECUTED\n"
 235:                 f"{order['instrument_name']}: {order['volume']}x @ {order['price']:.2f} SEK\n"
 236:                 f"Total: {order['total_sek']:,.0f} SEK\n"
 237:                 f"Order ID: {order_id}"
 238:             )
 239:             logger.info("Order executed: %s (avanza_id=%s)", order["id"], order_id)
 240:         else:
 241:             order["status"] = "failed"
 242:             order["error"] = msg_text
 243:             msg = (
 244:                 f"AVANZA {action} FAILED\n"
 245:                 f"{order['instrument_name']}: {order['volume']}x @ {order['price']:.2f} SEK\n"
 246:                 f"Error: {msg_text}"
 247:             )
 248:             logger.error("Order failed: %s — %s", order["id"], msg_text)
 249: 
 250:         send_telegram(msg, config)
 251: 
 252:     except Exception as e:
 253:         order["status"] = "error"
 254:         order["error"] = str(e)
 255:         logger.error("Order execution error: %s — %s", order["id"], e)
 256:         try:
 257:             send_telegram(
 258:                 f"AVANZA ORDER ERROR\n{order['instrument_name']}: {e}",
 259:                 config,
 260:             )

--- portfolio/avanza_resilient_page.py
   1: """Auto-recovering Playwright Page wrapper for Avanza-bound loops.
   2: 
   3: Problem: long-running loops (`data/metals_loop.py`, `portfolio/golddigger/`,
   4: `portfolio/main.py` via `avanza_session.py`) open a headless Chromium at
   5: startup and hold the `page` reference for days. When the browser dies
   6: (OS sleep, memory pressure, WSL ping hiccup, external BankID re-auth) the
   7: Python process keeps running but every `page.evaluate()` throws
   8: `playwright._impl._errors.TargetClosedError` — silently, for days. The
   9: bug discovered 2026-04-13: metals loop was emitting this error 662 times
  10: between 2026-04-09 and 2026-04-13, making zero trades.
  11: 
  12: Solution: pass a `ResilientPage` instead of a raw Playwright `Page`. On
  13: `TargetClosedError` (or equivalent browser-dead message) the wrapper tears
  14: down the dead browser+context, relaunches Chromium, reloads the saved
  15: `avanza_storage_state.json`, and retries the failing call once. Only then
  16: does it propagate the error.
  17: 
  18: This is the minimal surface — `evaluate()` and `context.cookies()` — that
  19: the existing helpers use. Other Page methods pass through unchanged via
  20: `__getattr__`; they get no auto-recovery (good enough: they're only used
  21: during startup, where crash-and-bat-restart is acceptable).
  22: 
  23: Usage:
  24: 
  25:     with sync_playwright() as pw:
  26:         page = ResilientPage.open(pw, "data/avanza_storage_state.json")
  27:         # pass `page` to existing helpers — zero call-site changes needed
  28:         fetch_price(page, ob_id, api_type)
  29:         fetch_account_cash(page, account_id)
  30:         # on shutdown:
  31:         page.close()
  32: """
  33: 
  34: from __future__ import annotations
  35: 
  36: import datetime
  37: import logging
  38: from typing import Any
  39: 
  40: logger = logging.getLogger("portfolio.avanza_resilient_page")
  41: 
  42: _INITIAL_URL = "https://www.avanza.se/min-ekonomi/oversikt.html"
  43: _INITIAL_URL_WAIT_MS = 2000
  44: 
  45: 
  46: def is_browser_dead_error(exc: BaseException) -> bool:
  47:     """True if ``exc`` signals a dead Playwright browser/context.
  48: 
  49:     Checks both the exception class name (Playwright's
  50:     ``TargetClosedError`` name changed across versions) and the message
  51:     (the stable cross-version signal). Exposed for tests and for
  52:     ``avanza_session.py`` which wants the same classifier without
  53:     importing Playwright internals.
  54:     """
  55:     name = type(exc).__name__
  56:     if name == "TargetClosedError":
  57:         return True
  58:     msg = str(exc)
  59:     for marker in (
  60:         "Target page, context or browser has been closed",
  61:         "Target closed",
  62:         "Browser has been closed",
  63:         "has been closed",
  64:     ):
  65:         if marker in msg:
  66:             return True
  67:     return False
  68: 
  69: 
  70: class ResilientPage:
  71:     """Playwright ``Page`` wrapper that auto-relaunches the browser on death."""
  72: 
  73:     def __init__(
  74:         self,
  75:         pw: Any,
  76:         storage_state_path: str,
  77:         *,
  78:         headless: bool = True,
  79:         locale: str = "sv-SE",
  80:         initial_url: str | None = _INITIAL_URL,
  81:         initial_url_wait_ms: int = _INITIAL_URL_WAIT_MS,
  82:     ) -> None:
  83:         self._pw = pw
  84:         self._storage_state_path = storage_state_path
  85:         self._headless = headless
  86:         self._locale = locale
  87:         self._initial_url = initial_url
  88:         self._initial_url_wait_ms = initial_url_wait_ms
  89:         self._browser = None
  90:         self._ctx = None
  91:         self._page = None
  92:         self._relaunch_count = 0
  93:         self._last_relaunch_ts: str | None = None
  94: 
  95:     @classmethod
  96:     def open(
  97:         cls,
  98:         pw: Any,
  99:         storage_state_path: str,
 100:         *,
 101:         headless: bool = True,
 102:         locale: str = "sv-SE",
 103:         initial_url: str | None = _INITIAL_URL,
 104:         initial_url_wait_ms: int = _INITIAL_URL_WAIT_MS,
 105:     ) -> ResilientPage:
 106:         """Construct and open the browser. Preferred entry point."""
 107:         rp = cls(
 108:             pw,
 109:             storage_state_path,
 110:             headless=headless,
 111:             locale=locale,
 112:             initial_url=initial_url,
 113:             initial_url_wait_ms=initial_url_wait_ms,
 114:         )
 115:         rp._open()
 116:         return rp
 117: 
 118:     def _open(self) -> None:
 119:         self._browser = self._pw.chromium.launch(headless=self._headless)
 120:         self._ctx = self._browser.new_context(
 121:             storage_state=self._storage_state_path,
 122:             locale=self._locale,
 123:         )
 124:         self._page = self._ctx.new_page()
 125:         if self._initial_url:
 126:             self._page.goto(self._initial_url, wait_until="domcontentloaded")
 127:             if self._initial_url_wait_ms:
 128:                 self._page.wait_for_timeout(self._initial_url_wait_ms)
 129: 
 130:     def _close_quietly(self) -> None:
 131:         for closer in (self._ctx, self._browser):
 132:             if closer is None:
 133:                 continue
 134:             try:
 135:                 closer.close()
 136:             except Exception as exc:
 137:                 logger.debug("ResilientPage teardown: %s", exc)
 138:         self._ctx = None
 139:         self._browser = None
 140:         self._page = None
 141: 
 142:     def _relaunch(self, *, reason: str) -> None:
 143:         self._relaunch_count += 1
 144:         self._last_relaunch_ts = datetime.datetime.now(datetime.UTC).isoformat()
 145:         logger.warning(
 146:             "ResilientPage: browser dead (%s) — relaunching (count=%d)",
 147:             reason, self._relaunch_count,
 148:         )
 149:         self._close_quietly()
 150:         self._open()
 151: 
 152:     def close(self) -> None:
 153:         """Teardown browser. Safe to call multiple times."""
 154:         self._close_quietly()
 155: 
 156:     # --- Recovery-aware proxy API ---
 157: 
 158:     def evaluate(self, script: str, arg: Any = None) -> Any:
 159:         """``page.evaluate(script, arg)`` with one-shot auto-recovery.
 160: 
 161:         On ``TargetClosedError`` (or equivalent), teardown + relaunch +
 162:         retry. If the retry also fails with a browser-dead error, propagate.
 163:         """
 164:         try:
 165:             if arg is None:
 166:                 return self._page.evaluate(script)
 167:             return self._page.evaluate(script, arg)
 168:         except Exception as exc:
 169:             if not is_browser_dead_error(exc):
 170:                 raise
 171:             self._relaunch(reason="evaluate")
 172:             if arg is None:
 173:                 return self._page.evaluate(script)
 174:             return self._page.evaluate(script, arg)
 175: 
 176:     def goto(self, *args, **kwargs) -> Any:
 177:         """``page.goto()`` with one-shot auto-recovery."""
 178:         try:
 179:             return self._page.goto(*args, **kwargs)
 180:         except Exception as exc:
 181:             if not is_browser_dead_error(exc):
 182:                 raise
 183:             self._relaunch(reason="goto")
 184:             return self._page.goto(*args, **kwargs)
 185: 
 186:     @property
 187:     def context(self):
 188:         """Return a context proxy whose ``cookies()`` auto-recovers."""
 189:         return _ResilientContextProxy(self)
 190: 
 191:     # Passthrough for everything else (wait_for_timeout, locator, on, etc.)
 192:     def __getattr__(self, name: str) -> Any:
 193:         # __getattr__ only fires when normal lookup fails — so this does
 194:         # NOT shadow evaluate/goto/context/close defined above.
 195:         if name.startswith("_"):
 196:             raise AttributeError(name)
 197:         target = self.__dict__.get("_page")
 198:         if target is None:
 199:             raise AttributeError(name)
 200:         return getattr(target, name)
 201: 
 202:     # --- Observability ---
 203: 
 204:     @property
 205:     def relaunch_count(self) -> int:
 206:         return self._relaunch_count
 207: 
 208:     @property
 209:     def last_relaunch_ts(self) -> str | None:
 210:         return self._last_relaunch_ts
 211: 
 212: 
 213: class _ResilientContextProxy:
 214:     """Proxy for ``BrowserContext`` that auto-recovers ``cookies()`` calls."""
 215: 
 216:     def __init__(self, resilient_page: ResilientPage) -> None:
 217:         self._rp = resilient_page
 218: 
 219:     def cookies(self) -> list[dict]:
 220:         try:
 221:             return self._rp._ctx.cookies()
 222:         except Exception as exc:
 223:             if not is_browser_dead_error(exc):
 224:                 raise
 225:             self._rp._relaunch(reason="context.cookies")
 226:             return self._rp._ctx.cookies()
 227: 
 228:     def __getattr__(self, name: str) -> Any:
 229:         if name.startswith("_"):
 230:             raise AttributeError(name)
 231:         return getattr(self._rp._ctx, name)

--- portfolio/avanza_session.py
   1: """Avanza session management — load, validate, and use BankID-captured sessions.
   2: 
   3: Uses Playwright's saved storage state to make authenticated API calls via a
   4: headless browser context. This ensures cookies and TLS session match what
   5: Avanza expects (replaying cookies via requests library causes 401s).
   6: 
   7: This is the preferred auth method until TOTP credentials are configured.
   8: """
   9: 
  10: import json
  11: import logging
  12: import threading
  13: import time
  14: from collections.abc import Callable
  15: from datetime import UTC, date, datetime, timedelta
  16: from pathlib import Path
  17: from typing import Any
  18: 
  19: from portfolio.avanza_order_lock import avanza_order_lock
  20: from portfolio.avanza_resilient_page import is_browser_dead_error
  21: from portfolio.file_utils import load_json
  22: 
  23: logger = logging.getLogger("portfolio.avanza_session")
  24: 
  25: BASE_DIR = Path(__file__).resolve().parent.parent
  26: DATA_DIR = BASE_DIR / "data"
  27: SESSION_FILE = DATA_DIR / "avanza_session.json"
  28: STORAGE_STATE_FILE = DATA_DIR / "avanza_storage_state.json"
  29: API_BASE = "https://www.avanza.se"
  30: 
  31: # Minimum remaining session life before we consider it expired (minutes)
  32: EXPIRY_BUFFER_MINUTES = 30
  33: 
  34: # Default trading account
  35: DEFAULT_ACCOUNT_ID = "1625505"
  36: 
  37: # Whitelist of permitted account IDs — never trade outside these
  38: ALLOWED_ACCOUNT_IDS = {"1625505"}
  39: 
  40: # Module-level Playwright context (lazy-initialized, reused across calls)
  41: # BUG-129: Protected by _pw_lock to prevent concurrent access corruption
  42: # A-AV-1 (2026-04-11): Upgraded to RLock so api_get/api_post/api_delete can
  43: # wrap their *entire* request flow under the lock — they call
  44: # _get_playwright_context() (which itself acquires the lock) inside the
  45: # critical section. The previous Lock would deadlock; RLock is reentrant
  46: # for the same thread. Without this, Playwright's sync_api was being used
  47: # concurrently from main loop's 8-worker pool + metals 10s fast-tick,
  48: # corrupting trade responses (e.g. CONFIRM stolen by wrong request).
  49: _pw_lock = threading.RLock()
  50: _pw_instance = None
  51: _pw_browser = None
  52: _pw_context = None
  53: 
  54: 
  55: class AvanzaSessionError(Exception):
  56:     """Raised when session is missing, expired, or invalid."""
  57: 
  58: 
  59: def load_session() -> dict:
  60:     """Load saved BankID session metadata from disk.
  61: 
  62:     Returns:
  63:         Session dict with expiry info, customer_id, etc.
  64: 
  65:     Raises:
  66:         AvanzaSessionError: if file missing, unreadable, or expired.
  67:     """
  68:     if not SESSION_FILE.exists():
  69:         raise AvanzaSessionError(
  70:             f"No session file found at {SESSION_FILE}. "
  71:             "Run: python scripts/avanza_login.py"
  72:         )
  73: 
  74:     data = load_json(SESSION_FILE)
  75:     if data is None:
  76:         raise AvanzaSessionError(f"Failed to read session file: {SESSION_FILE}")
  77: 
  78:     # Check expiry
  79:     expires_at = data.get("expires_at")
  80:     if expires_at:
  81:         try:
  82:             exp = datetime.fromisoformat(expires_at)
  83:             now = datetime.now(UTC)
  84:             if exp <= now:
  85:                 raise AvanzaSessionError(
  86:                     f"Session expired at {expires_at}. "
  87:                     "Run: python scripts/avanza_login.py"
  88:                 )
  89:         except ValueError:
  90:             logger.warning("Cannot parse expires_at %r — cannot verify expiry, proceeding with caution", expires_at)
  91: 
  92:     if not STORAGE_STATE_FILE.exists():
  93:         raise AvanzaSessionError(
  94:             f"No storage state file at {STORAGE_STATE_FILE}. "
  95:             "Run: python scripts/avanza_login.py"
  96:         )
  97: 
  98:     return data
  99: 
 100: 
 101: def session_remaining_minutes() -> float | None:
 102:     """Get minutes remaining on the current session, or None if no session."""
 103:     try:
 104:         data = load_json(SESSION_FILE)
 105:         if data is None:
 106:             return None
 107:         expires_at = data.get("expires_at")
 108:         if not expires_at:
 109:             return None
 110:         exp = datetime.fromisoformat(expires_at)
 111:         now = datetime.now(UTC)
 112:         return (exp - now).total_seconds() / 60.0
 113:     except Exception as e:
 114:         logger.warning("Failed to compute session minutes remaining: %s", e)
 115:         return None
 116: 
 117: 
 118: def is_session_expiring_soon(threshold_minutes: float = 60.0) -> bool:
 119:     """Check if session will expire within the given threshold.
 120: 
 121:     Returns True if session is expired, expiring soon, or doesn't exist.
 122:     """
 123:     remaining = session_remaining_minutes()
 124:     if remaining is None:
 125:         return True
 126:     return remaining < threshold_minutes
 127: 
 128: 
 129: def _get_playwright_context():
 130:     """Get or create a headless Playwright browser context with saved auth state."""
 131:     global _pw_instance, _pw_browser, _pw_context
 132: 
 133:     with _pw_lock:
 134:         if _pw_context is not None:
 135:             return _pw_context
 136: 
 137:         # Validate session first
 138:         load_session()
 139: 
 140:         from playwright.sync_api import sync_playwright
 141: 
 142:         _pw_instance = sync_playwright().start()
 143:         _pw_browser = _pw_instance.chromium.launch(headless=True)
 144:         _pw_context = _pw_browser.new_context(
 145:             storage_state=str(STORAGE_STATE_FILE),
 146:             locale="sv-SE",
 147:         )
 148:         return _pw_context
 149: 
 150: 
 151: def close_playwright():
 152:     """Clean up Playwright resources."""
 153:     global _pw_instance, _pw_browser, _pw_context
 154:     with _pw_lock:
 155:         if _pw_context:
 156:             try:
 157:                 _pw_context.close()
 158:             except Exception as e:
 159:                 logger.debug("Context close failed: %s", e)
 160:             _pw_context = None
 161:         if _pw_browser:
 162:             try:
 163:                 _pw_browser.close()
 164:             except Exception as e:
 165:                 logger.debug("Browser close failed: %s", e)
 166:             _pw_browser = None
 167:         if _pw_instance:
 168:             try:
 169:                 _pw_instance.stop()
 170:             except Exception as e:
 171:                 logger.debug("Playwright stop failed: %s", e)
 172:             _pw_instance = None
 173: 
 174: 
 175: def verify_session() -> bool:
 176:     """Verify that the session is valid by making a lightweight API call.
 177: 
 178:     Returns:
 179:         True if session is valid, False otherwise.
 180:     """
 181:     # A-AV-1: Hold _pw_lock for the entire context+request flow.
 182:     # ctx.request.* is NOT thread-safe; concurrent callers must serialize.
 183:     try:
 184:         with _pw_lock:
 185:             ctx = _get_playwright_context()
 186:             resp = ctx.request.get(f"{API_BASE}/_api/position-data/positions")
 187:             return resp.ok
 188:     except Exception as e:
 189:         logger.warning("Session verification failed: %s", e)
 190:         close_playwright()
 191:         return False
 192: 
 193: 
 194: # 2026-04-13: Auto-recovery wrapper for api_get/api_post/api_delete.
 195: # The singleton Playwright browser held in _pw_context occasionally dies
 196: # mid-flight (OS sleep, memory pressure, external BankID re-auth by the
 197: # user, cookie-jar corruption under heavy concurrency). When that happens
 198: # every subsequent ctx.request.* call throws TargetClosedError until the
 199: # process restarts. The pre-existing 401/403 path already knows to call
 200: # close_playwright() so the next request re-launches; we extend the same
 201: # pattern to browser-dead errors.
 202: #
 203: # Keeps the singleton + _pw_lock (BUG-129 / A-AV-1). The whole retry runs
 204: # under the RLock so a concurrent thread cannot partially observe the
 205: # teardown/relaunch. _get_playwright_context also acquires the lock but
 206: # it's reentrant for the same thread.
 207: def _with_browser_recovery(op: Callable[[Any], Any], *, op_name: str) -> Any:
 208:     """Run ``op(ctx)`` under ``_pw_lock``; on browser-dead error, teardown +
 209:     relaunch + retry once. Propagate all other exceptions unchanged.
 210: 
 211:     ``op`` is called with the current Playwright context. The op is responsible
 212:     for making the actual ctx.request.* call and handling HTTP-level errors.
 213:     """
 214:     with _pw_lock:
 215:         ctx = _get_playwright_context()
 216:         try:
 217:             return op(ctx)
 218:         except Exception as exc:
 219:             if not is_browser_dead_error(exc):
 220:                 raise
 221:             logger.warning(
 222:                 "avanza_session: browser dead on %s (%r) — teardown + relaunch + retry",
 223:                 op_name, exc,
 224:             )
 225:             close_playwright()
 226:             ctx = _get_playwright_context()
 227:             return op(ctx)
 228: 
 229: 
 230: # --- API convenience functions ---
 231: 
 232: 
 233: def api_get(path: str, **kwargs) -> Any:
 234:     """Make an authenticated GET request to Avanza API.
 235: 
 236:     Args:
 237:         path: API path (e.g., "/_api/position-data/positions")
 238: 
 239:     Returns:
 240:         Parsed JSON response.
 241: 
 242:     Raises:
 243:         AvanzaSessionError: if session is invalid.
 244:     """
 245:     # A-AV-1: Hold _pw_lock for the entire request. Playwright's sync_api
 246:     # is NOT thread-safe and the metals fast-tick + main 8-worker pool race.
 247:     # 2026-04-13: Wrapped in _with_browser_recovery so TargetClosedError
 248:     # (browser died mid-flight) triggers a teardown + relaunch + retry.
 249:     url = f"{API_BASE}{path}" if path.startswith("/") else path
 250: 
 251:     def _op(ctx):
 252:         resp = ctx.request.get(url)
 253:         if resp.status == 401:
 254:             close_playwright()
 255:             raise AvanzaSessionError(
 256:                 "Session returned 401 Unauthorized. "
 257:                 "Run: python scripts/avanza_login.py"
 258:             )
 259:         if not resp.ok:
 260:             raise RuntimeError(f"Avanza API error {resp.status}: {resp.text()[:500]}")


