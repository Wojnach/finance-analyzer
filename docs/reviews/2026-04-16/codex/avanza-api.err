   1: """Avanza API client for portfolio monitoring and trading.
   2: 
   3: Supports two authentication methods:
   4: 1. BankID session (preferred) — captured by scripts/avanza_login.py, stored in
   5:    data/avanza_session.json. No credentials needed, valid ~24h.
   6: 2. TOTP credentials (fallback) — uses avanza-api library with username/password/TOTP
   7:    from config.json.
   8: 
   9: The client transparently tries BankID session first, then falls back to TOTP.
  10: """
  11: 
  12: import logging
  13: from datetime import date
  14: from pathlib import Path
  15: from typing import Any
  16: 
  17: from portfolio.file_utils import load_json
  18: 
  19: logger = logging.getLogger("portfolio.avanza_client")
  20: 
  21: BASE_DIR = Path(__file__).resolve().parent.parent
  22: CONFIG_FILE = BASE_DIR / "config.json"
  23: 
  24: # A-AV-2 (2026-04-11): Hardcoded account whitelist. The TOTP path scans for
  25: # any account whose accountType contains "ISK", which means a future Avanza
  26: # response containing a *new* ISK-shaped account (e.g. a child's ISK or a
  27: # corporate ISK) could be picked up as the trading account. Worse, the
  28: # pension account (2674244) was previously reachable through some code paths
  29: # without filtering. Mirror the ALLOWED_ACCOUNT_IDS pattern from
  30: # avanza_session.py: anything not in this set is rejected, period.
  31: ALLOWED_ACCOUNT_IDS: set[str] = {"1625505"}
  32: 
  33: # Singleton client instance (avanza-api library)
  34: _client = None
  35: # Cached signal that a BankID Playwright session has already been verified.
  36: _session_client = None
  37: 
  38: 
  39: def _load_credentials() -> dict:
  40:     """Load Avanza credentials from config.json.
  41: 
  42:     Returns:
  43:         dict with keys: username, password, totp_secret
  44: 
  45:     Raises:
  46:         FileNotFoundError: if config.json does not exist
  47:         KeyError: if 'avanza' section is missing or credentials incomplete
  48:     """
  49:     config = load_json(CONFIG_FILE)
  50:     if config is None:
  51:         raise FileNotFoundError(f"Config file not found or unreadable: {CONFIG_FILE}")
  52:     if "avanza" not in config:
  53:         raise KeyError(
  54:             "Missing 'avanza' section in config.json. "
  55:             "Add: {\"avanza\": {\"username\": \"...\", \"password\": \"...\", \"totp_secret\": \"...\"}}"
  56:         )
  57:     creds = config["avanza"]
  58:     for key in ("username", "password", "totp_secret"):
  59:         if key not in creds or not creds[key]:
  60:             raise KeyError(f"Missing or empty 'avanza.{key}' in config.json")
  61:     return creds
  62: 
  63: 
  64: def _try_session_auth() -> bool:
  65:     """Return True when a BankID-backed Playwright session is available."""
  66:     global _session_client
  67:     if _session_client is True:
  68:         return True
  69:     try:
  70:         from portfolio.avanza_session import verify_session
  71:         if verify_session():
  72:             _session_client = True
  73:             logger.info("Using BankID session for Avanza API")
  74:             return True
  75:         logger.info("BankID session exists but verification failed")
  76:     except Exception as e:
  77:         logger.debug("BankID session not available: %s", e)
  78:     return False
  79: 
  80: 
  81: def get_client():
  82:     """Get or create a singleton Avanza client.
  83: 
  84:     Tries BankID session first, then falls back to TOTP credentials.
  85: 
  86:     Returns:
  87:         Authenticated Avanza client instance (avanza-api library)
  88: 
  89:     Raises:
  90:         Exception: if neither auth method works
  91:     """
  92:     global _client
  93:     if _client is not None:
  94:         return _client
  95:     try:
  96:         from avanza import Avanza
  97:     except ImportError:
  98:         raise ImportError(
  99:             "avanza-api package not installed. Run: pip install avanza-api"
 100:         ) from None
 101:     creds = _load_credentials()
 102:     _client = Avanza({
 103:         "username": creds["username"],
 104:         "password": creds["password"],
 105:         "totpSecret": creds["totp_secret"],
 106:     })
 107:     return _client
 108: 
 109: 
 110: def reset_client() -> None:
 111:     """Reset the singleton TOTP client (useful for re-authentication)."""
 112:     global _client
 113:     _client = None
 114: 
 115: 
 116: def reset_session() -> None:
 117:     """Reset the cached BankID session verification flag."""
 118:     global _session_client
 119:     _session_client = None
 120: 
