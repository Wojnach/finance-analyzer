  21:     fd, tmp = tempfile.mkstemp(dir=str(path.parent), suffix=".tmp")
  22:     try:
  23:         with os.fdopen(fd, "w", encoding="utf-8") as f:
  24:             json.dump(data, f, indent=indent, default=str, ensure_ascii=ensure_ascii)
  25:             f.flush()
  26:             os.fsync(f.fileno())
  27:         os.replace(tmp, str(path))
  28:     except BaseException:
  29:         with suppress(OSError):
  30:             os.unlink(tmp)
  31:         raise
