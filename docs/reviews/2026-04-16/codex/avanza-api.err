  13: def atomic_write_json(path, data, indent=2, ensure_ascii=True):
  14:     """Atomically write JSON data to a file using tempfile + os.replace.
  15: 
  16:     Ensures the file is never left in a partially-written state.
  17:     Fsyncs before replace to guarantee durability on power loss (H34).
  18:     """
  19:     path = Path(path)
