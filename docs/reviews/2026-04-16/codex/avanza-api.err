  72: def load_jsonl(path, limit=None):
  73:     """Load entries from a JSONL file.
  74: 
  75:     Args:
  76:         path: Path to the .jsonl file.
  77:         limit: If set, keep only the *last* N entries (uses a deque).
  78: 
  79:     Returns:
  80:         list of parsed dicts. Empty list if file missing or empty.
  81:     """
  82:     path = Path(path)
  83:     container = deque(maxlen=limit) if limit else []
  84:     try:
  85:         f = open(path, encoding="utf-8")
  86:     except FileNotFoundError:
  87:         return []
  88:     with f:
  89:         for line in f:
  90:             line = line.strip()
  91:             if not line:
  92:                 continue
  93:             try:
  94:                 container.append(json.loads(line))
  95:             except json.JSONDecodeError as e:
  96:                 logger.debug("Skipping malformed JSONL line in %s: %s", path.name, str(e)[:100])
  97:                 continue
  98:     return list(container)
