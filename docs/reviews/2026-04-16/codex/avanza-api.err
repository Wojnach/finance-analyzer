 161: def get_positions() -> list[dict]:
 162:     """Get all current positions from the Avanza account.
 163: 
 164:     Tries BankID session first, then falls back to TOTP client.
 165: 
 166:     Returns:
 167:         List of position dicts, each with name, value, profit, etc.
 168:         Returns empty list if no positions or on error.
 169:     """
 170:     # Try session-based auth first
 171:     if _try_session_auth():
 172:         try:
 173:             from portfolio.avanza_session import get_positions as session_get_positions
 174:             return session_get_positions()
 175:         except Exception as e:
 176:             logger.warning("Session-based positions fetch failed, trying TOTP: %s", e)
 177:             reset_session()
 178: 
 179:     client = get_client()
 180:     overview = client.get_overview()
 181:     positions = []
 182:     # A-AV-2: only return positions from whitelisted accounts so the pension
 183:     # account (or any future-added account) never leaks into the trading view.
 184:     for account in overview.get("accounts", []):
 185:         if str(account.get("accountId", "")) not in ALLOWED_ACCOUNT_IDS:
 186:             continue
 187:         for pos in account.get("positions", []):
 188:             positions.append({
 189:                 "account": account.get("name", ""),
 190:                 "account_id": account.get("accountId", ""),
 191:                 "name": pos.get("name", ""),
 192:                 "ticker": pos.get("orderbookId", ""),
 193:                 "volume": pos.get("volume", 0),
 194:                 "value": pos.get("value", 0),
 195:                 "profit": pos.get("profit", 0),
 196:                 "profit_percent": pos.get("profitPercent", 0),
 197:                 "currency": pos.get("currency", "SEK"),
 198:             })
 199:     return positions
 200: 
 201: 
 202: def get_portfolio_value() -> float:
 203:     """Get total portfolio value in SEK for whitelisted Avanza accounts only.
 204: 
 205:     A-AV-2: Filters to ALLOWED_ACCOUNT_IDS so pension/other-account values
 206:     never inflate the "trading" portfolio value used for sizing.
 207: 
 208:     Returns:
 209:         Total portfolio value in SEK across whitelisted accounts
 210:     """
 211:     client = get_client()
 212:     overview = client.get_overview()
 213:     total = 0.0
 214:     for account in overview.get("accounts", []):
 215:         if str(account.get("accountId", "")) not in ALLOWED_ACCOUNT_IDS:
 216:             continue
 217:         total += account.get("totalValue", 0)
 218:     return total
 219: 
 220: 
 221: def get_open_orders() -> list:
 222:     """Return open orders for the ISK account (read-only).
 223: 
 224:     Uses the authenticated Avanza client; does not place or cancel orders.
 225:     """
 226:     client = get_client()
 227:     account_id = get_account_id()
 228:     try:
 229:         orders = client.get_orders(account_id)
 230:     except Exception as e:
 231:         logger.error("Failed to fetch open orders: %s", e)
 232:         raise
 233:     return orders or []
 234: 
