import pathlib, ast
root = pathlib.Path(r'Q:/finance-analyzer-fgl-review/.codex_review_snapshot_393e2a8_zip/portfolio')
existing = {p.stem for p in root.glob('*.py')}
missing = {}
for path in sorted((root/'signals').glob('*.py')):
    tree = ast.parse(path.read_text())
    miss=[]
    for node in ast.walk(tree):
        if isinstance(node, ast.ImportFrom) and node.module and node.module.startswith('portfolio.'):
            mod = node.module.split('.',1)[1]
            if mod not in existing and not (root/mod).is_dir():
                miss.append(node.module)
        elif isinstance(node, ast.Import):
            for alias in node.names:
                if alias.name.startswith('portfolio.'):
                    mod = alias.name.split('.',1)[1]
                    if mod not in existing and not (root/mod).is_dir():
                        miss.append(alias.name)
    if miss:
        missing[path.name]=sorted(set(miss))
print(missing)
