    fns=[]
    for node in tree.body:
        if isinstance(node, ast.FunctionDef):
            args=[a.arg for a in node.args.args]
            fns.append(f\"{node.name}({', '.join(args)})\")
        elif isinstance(node, ast.Assign):
            pass
    print('\\n'+path.name)
    for fn in fns[:20]:
