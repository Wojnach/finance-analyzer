import importlib.util, sys, types, pathlib, traceback
import numpy as np, pandas as pd

root = pathlib.Path(r'Q:/finance-analyzer-fgl-review/reviewsnapshot393e/portfolio/signals')
# reset sys modules helpers maybe isolated script
portfolio = types.ModuleType('portfolio'); portfolio.__path__ = []
sys.modules['portfolio'] = portfolio
sig = types.ModuleType('portfolio.signal_utils')

def safe_float(v, default=float('nan')):
    try: return float(v)
    except: return default

def sma(series, period): return pd.Series(series).rolling(period).mean()
def ema(series, period): return pd.Series(series).ewm(span=period, adjust=False).mean()
def wma(series, period):
    s=pd.Series(series); w=np.arange(1,period+1)
    return s.rolling(period).apply(lambda x:(x*w).sum()/w.sum(), raw=True)
def rma(series, period): return pd.Series(series).ewm(alpha=1/period, adjust=False).mean()
def true_range(high,low,close):
    h,l,c = pd.Series(high), pd.Series(low), pd.Series(close); pc=c.shift(1)
    return pd.concat([(h-l),(h-pc).abs(),(l-pc).abs()],axis=1).max(axis=1)
def rsi(close, period=14):
    c=pd.Series(close); d=c.diff(); gain=d.clip(lower=0); loss=-d.clip(upper=0)
    ag=gain.ewm(alpha=1/period,adjust=False).mean(); al=loss.ewm(alpha=1/period,adjust=False).mean(); rs=ag/al.replace(0,np.nan)
    return (100-100/(1+rs)).fillna(50)
def roc(series, period=1): return pd.Series(series).pct_change(periods=period)*100
def majority_vote(votes):
    vals=[v for v in votes if v in {'BUY','SELL','HOLD'}]
    if not vals: return 'HOLD',0.0
    counts={k:vals.count(k) for k in ('BUY','SELL','HOLD')}
    a=max(counts,key=counts.get); return a, counts[a]/len(vals)
