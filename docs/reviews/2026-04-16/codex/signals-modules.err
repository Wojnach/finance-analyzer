"C:\\Program Files\\PowerShell\\7\\pwsh.exe" -Command "@'
import importlib.util, sys, types, pathlib, math, traceback
import numpy as np, pandas as pd

root = pathlib.Path(r'Q:/finance-analyzer-fgl-review/reviewsnapshot393e/portfolio/signals')

# stub package
portfolio = types.ModuleType('portfolio'); portfolio.__path__ = []
sys.modules['portfolio'] = portfolio

sig = types.ModuleType('portfolio.signal_utils')

def safe_float(v, default=float('nan')):
    try:
        return float(v)
    except Exception:
        return default

def sma(series, period):
    return pd.Series(series).rolling(period).mean()

def ema(series, period):
    return pd.Series(series).ewm(span=period, adjust=False).mean()

def wma(series, period):
    s = pd.Series(series)
    weights = np.arange(1, period+1)
    return s.rolling(period).apply(lambda x: np.dot(x, weights)/weights.sum(), raw=True)

def rma(series, period):
    s = pd.Series(series)
    return s.ewm(alpha=1/period, adjust=False).mean()

def true_range(high, low, close):
    high = pd.Series(high); low = pd.Series(low); close = pd.Series(close)
    prev_close = close.shift(1)
    return pd.concat([(high-low), (high-prev_close).abs(), (low-prev_close).abs()], axis=1).max(axis=1)

def rsi(close, period=14):
    c = pd.Series(close)
    delta = c.diff()
    gain = delta.clip(lower=0)
    loss = -delta.clip(upper=0)
    avg_gain = gain.ewm(alpha=1/period, adjust=False).mean()
    avg_loss = loss.ewm(alpha=1/period, adjust=False).mean()
    rs = avg_gain / avg_loss.replace(0, np.nan)
    out = 100 - 100 / (1 + rs)
    return out.fillna(50)

def roc(series, period=1):
    s = pd.Series(series)
    return s.pct_change(periods=period)*100

def majority_vote(votes):
    vals = [v for v in votes if v in ('BUY','SELL','HOLD')]
    if not vals:
        return 'HOLD', 0.0
    counts = {k: vals.count(k) for k in ('BUY','SELL','HOLD')}
    action = max(counts, key=counts.get)
    confidence = counts[action] / len(vals)
    return action, round(confidence, 3)

for n,v in list(locals().items()):
    if n in {'safe_float','sma','ema','wma','rma','true_range','rsi','roc','majority_vote'}:
        setattr(sig, n, v)
sys.modules['portfolio.signal_utils'] = sig
setattr(portfolio, 'signal_utils', sig)

# other stubs
fomc = types.ModuleType('portfolio.fomc_dates'); fomc.get_upcoming_fomc_dates = lambda *a, **k: [] ; fomc.get_fomc_dates = lambda *a, **k: []
sys.modules['portfolio.fomc_dates'] = fomc
setattr(portfolio,'fomc_dates',fomc)
season = types.ModuleType('portfolio.seasonality'); season.seasonal_bias = lambda *a, **k: 0; season.apply_seasonality = lambda action, conf, *a, **k: (action, conf)
sys.modules['portfolio.seasonality'] = season
setattr(portfolio,'seasonality',season)
macro_context = types.ModuleType('portfolio.macro_context'); macro_context.get_macro_context = lambda *a, **k: {}
sys.modules['portfolio.macro_context'] = macro_context
setattr(portfolio,'macro_context',macro_context)

# Build df
n=300
rng=np.random.default_rng(0)
idx = pd.date_range('2025-01-01', periods=n, freq='D')
base = np.linspace(100, 130, n) + np.sin(np.arange(n)/10)*3
open_ = pd.Series(base + rng.normal(0,1,n), index=idx)
close = pd.Series(base + rng.normal(0,1,n), index=idx)
high = pd.Series(np.maximum(open_, close) + rng.uniform(0,2,n), index=idx)
low = pd.Series(np.minimum(open_, close) - rng.uniform(0,2,n), index=idx)
vol = pd.Series(rng.integers(1000,2000,n), index=idx)
df = pd.DataFrame({'Open':open_,'High':high,'Low':low,'Close':close,'Volume':vol})
for c in list(df.columns):
    df[c.lower()] = df[c]

files = [
    'calendar_seasonal.py','candlestick.py','dxy_cross_asset.py','fibonacci.py',
    'heikin_ashi.py','hurst_regime.py','macro_regime.py','mean_reversion.py',
    'momentum.py','momentum_factors.py','oscillators.py','shannon_entropy.py',
    'smart_money.py','structure.py','trend.py','volatility.py','volume_flow.py'
]

for file in files:
    name = file[:-3]
    spec = importlib.util.spec_from_file_location(f'portfolio.signals.{name}', root / file)
    mod = importlib.util.module_from_spec(spec)
    sys.modules[spec.name] = mod
    try:
        spec.loader.exec_module(mod)
        fns = [getattr(mod, x) for x in dir(mod) if x.startswith('compute_')]
        fn = fns[0]
        try:
            argc = fn.__code__.co_argcount
            if argc == 1:
                result = fn(df)
            elif argc == 2:
                result = fn(df, {'ticker':'SPY', 'macro': {}})
            else:
                result = fn(df)
            print(file, 'OK', result.get('action') if isinstance(result, dict) else type(result), result.get('confidence') if isinstance(result, dict) else '')
        except Exception as e:
            print(file, 'RUNTIME_ERROR', repr(e))
            traceback.print_exc(limit=2)
    except Exception as e:
        print(file, 'IMPORT_ERROR', repr(e))
        traceback.print_exc(limit=2)
