        _log_invocation({
            "timestamp": now_iso,
            "caller": caller,
            "status": "blocked",
            "reason": "CLAUDE_ENABLED=False",
            "model": model,
            "max_turns": max_turns,
            "duration_seconds": 0,
            "exit_code": -1,
        })
        return False, -1

    # --- Gate 2: config.json layer2.enabled ---
    if not _load_config_layer2_enabled():
