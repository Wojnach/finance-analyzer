--- portfolio/multi_agent_layer2.py 180
 180:     procs: list[subprocess.Popen],
 181:     timeout: int = 150,
 182: ) -> dict[str, bool]:
 183:     """Wait for all specialist agents to complete.
 184: 
 185:     Returns dict of specialist_name -> success (True/False).
 186:     """
 187:     results = {}
 188:     deadline = time.time() + timeout
 189: 
 190:     for proc in procs:
 191:         remaining = max(1, deadline - time.time())
 192:         name = getattr(proc, "_name", "unknown")
 193:         try:
 194:             proc.wait(timeout=remaining)
 195:             success = proc.returncode == 0
 196:             results[name] = success
 197:             if not success:
 198:                 logger.warning("Specialist %s exited with code %d", name, proc.returncode)
 199:         except subprocess.TimeoutExpired:
 200:             logger.warning("Specialist %s timed out, killing", name)
 201:             proc.kill()
 202:             proc.wait(timeout=5)
 203:             results[name] = False
 204:         finally:
 205:             log_fh = getattr(proc, "_log_fh", None)
 206:             if log_fh:
 207:                 log_fh.close()
 208: 
 209:         # 2026-04-13: Auth-error scan — specialist log is truncated per run

