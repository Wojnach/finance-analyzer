# demonstrate kelly sizing trade stats issue
transactions = [
    {'ticker':'ABC','action':'BUY','shares':1,'total_sek':100},
    {'ticker':'ABC','action':'SELL','shares':1,'total_sek':110},
    {'ticker':'ABC','action':'BUY','shares':1,'total_sek':200},
    {'ticker':'ABC','action':'SELL','shares':1,'total_sek':190},
]
from collections import defaultdict
buys_by_ticker = defaultdict(list); sells_by_ticker = defaultdict(list)
for t in transactions:
    if t['action']=='BUY': buys_by_ticker[t['ticker']].append(t)
    elif t['action']=='SELL': sells_by_ticker[t['ticker']].append(t)
pnl_list=[]
for t_ticker,sells in sells_by_ticker.items():
    buys=buys_by_ticker.get(t_ticker,[])
    total_shares_bought=sum(b.get('shares',0) for b in buys)
    total_cost=sum(b.get('total_sek',0) for b in buys)
    avg_buy_price=total_cost/total_shares_bought
    for sell in sells:
        sell_price_per_share = sell['total_sek']/sell['shares']
        pnl_pct=(sell_price_per_share-avg_buy_price)/avg_buy_price*100
        pnl_list.append(pnl_pct)
print('computed', pnl_list)
print('expected', [10,-5])
