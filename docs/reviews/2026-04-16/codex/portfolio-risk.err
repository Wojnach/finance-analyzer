 399: def log_portfolio_value(patient_path: str | None = None,
 400:                         bold_path: str | None = None,
 401:                         agent_summary_path: str | None = None):
 402:     """Append current portfolio values to data/portfolio_value_history.jsonl.
 403: 
 404:     Each entry contains:
 405:         - ts: ISO-8601 UTC timestamp
 406:         - patient_value_sek: total patient portfolio value
 407:         - bold_value_sek: total bold portfolio value
 408:         - patient_pnl_pct: patient P&L percentage
 409:         - bold_pnl_pct: bold P&L percentage
 410:         - prices: dict of current USD prices from agent_summary
 411: 
 412:     Args:
 413:         patient_path: Path to patient portfolio state JSON.
 414:         bold_path: Path to bold portfolio state JSON.
 415:         agent_summary_path: Path to agent_summary.json.
 416:     """
 417:     if patient_path is None:
 418:         patient_path = str(DATA_DIR / "portfolio_state.json")
 419:     if bold_path is None:
 420:         bold_path = str(DATA_DIR / "portfolio_state_bold.json")
 421:     if agent_summary_path is None:
 422:         agent_summary_path = str(DATA_DIR / "agent_summary.json")
 423: 
 424:     patient = load_json(patient_path, default={})
 425:     bold = load_json(bold_path, default={})
 426:     summary = load_json(agent_summary_path, default={"signals": {}, "fx_rate": 1.0})
 427: 
 428:     patient_value = _compute_portfolio_value(patient, summary)
 429:     bold_value = _compute_portfolio_value(bold, summary)
 430: 
 431:     patient_initial = patient.get("initial_value_sek", INITIAL_VALUE_DEFAULT)
 432:     bold_initial = bold.get("initial_value_sek", INITIAL_VALUE_DEFAULT)
 433: 
 434:     patient_pnl_pct = ((patient_value - patient_initial) / patient_initial) * 100 if patient_initial > 0 else 0
 435:     bold_pnl_pct = ((bold_value - bold_initial) / bold_initial) * 100 if bold_initial > 0 else 0


