{
  "strategy": "TABaseStrategy",
  "strategy_path": "user_data/strategies/",
  "trading_mode": "futures",
  "margin_mode": "isolated",
  "max_open_trades": 3,
  "stake_currency": "USDT",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.99,
  "fiat_display_currency": "USD",
  "dry_run": true,
  "dry_run_wallet": 1000,
  "cancel_open_orders_on_exit": false,
  "use_exit_signal": true,
  "exit_profit_only": false,
  "ignore_roi_if_entry_signal": false,
  "timeframe": "5m",
  "order_types": {
    "entry": "limit",
    "exit": "limit",
    "stoploss": "market",
    "stoploss_on_exchange": true
  },
  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "exchange": {
    "name": "binance",
    "key": "FAKE_KEY_replace_in_config_json",
    "secret": "FAKE_SECRET_replace_in_config_json",
    "ccxt_config": {},
    "ccxt_async_config": {},
    "pair_whitelist": ["BTC/USDT:USDT", "ETH/USDT:USDT"],
    "pair_blacklist": []
  },
  "entry_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },
  "exit_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "telegram": {
    "enabled": true,
    "token": "FAKE_TOKEN_replace_in_config_json",
    "chat_id": "FAKE_CHATID_replace_in_config_json",
    "keyboard": [
      ["/daily", "/stats", "/balance", "/profit"],
      ["/status table", "/performance"],
      ["/reload_config", "/count", "/logs"]
    ],
    "notification_settings": {
      "status": "on",
      "warning": "on",
      "startup": "on",
      "entry": "on",
      "exit": "on",
      "entry_cancel": "on",
      "exit_cancel": "on",
      "entry_fill": "on",
      "exit_fill": "on",
      "protection_trigger": "on",
      "protection_trigger_global": "on",
      "strategy_msg": "on",
      "show_candle": "ohlc"
    },
    "reload": true,
    "balance_dust_level": 0.01
  },
  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": true,
    "jwt_secret_key": "FAKE_JWT_replace_in_config_json",
    "ws_token": "FAKE_WS_TOKEN_replace_in_config_json",
    "CORS_origins": ["http://localhost:3000"],
    "username": "admin",
    "password": "FAKE_PASS_replace_in_config_json"
  },
  "alpaca": {
    "key": "FAKE_KEY_replace_in_config_json",
    "secret": "FAKE_SECRET_replace_in_config_json"
  },
  "newsapi_key": "",
  "forecast": {
    "chronos_model": "amazon/chronos-bolt-small",
    "kronos_enabled": false,
    "kronos_interval": "5m",
    "kronos_periods": 500,
    "kronos_temperature": 0.7,
    "kronos_top_p": 0.9,
    "kronos_samples": 3,
    "hold_threshold": 0.55,
    "min_samples": 10,
    "subsignal_hold_threshold": 0.55,
    "subsignal_min_samples": 10,
    "subsignal_accuracy_days": 30
  },
  "signals": {
    "accuracy_gate_threshold": 0.45,
    "accuracy_gate_min_samples": 30,
    "accuracy_halflife_days": 5,
    "max_active_signals": null,
    "use_best_horizon": true
  },
  "local_models": {
    "ministral": {
      "hold_threshold": 0.55,
      "min_samples": 30,
      "accuracy_days": 30
    }
  },
  "local_llm_report": {
    "daily_export_enabled": true,
    "report_days": 30,
    "history_max_entries": 366
  },
  "golddigger": {
    "poll_seconds": 5,
    "window_n": 720,
    "min_window": 60,
    "cert_api_type": "certificate",
    "w_gold": 0.5,
    "w_fx": 0.3,
    "w_yield": 0.2,
    "theta_in": 1.0,
    "theta_out": 0.2,
    "confirm_polls": 6,
    "binance_gold_symbol": "XAUUSDT",
    "fred_series": "DGS10",
    "use_signal_consensus": true,
    "use_macro_context": true,
    "use_volume_confirm": true,
    "volume_ratio_min": 0.75,
    "use_chronos_forecast": true,
    "rates_source": "auto",
    "rates_proxy_ticker": "^TNX",
    "rates_proxy_interval": "15m",
    "rates_proxy_lookback_bars": 5,
    "rates_proxy_ttl_seconds": 300,
    "rates_proxy_max_bar_age_minutes": 45,
    "use_intraday_dxy_gate": true,
    "dxy_proxy_ticker": "DX-Y.NYB",
    "dxy_proxy_interval": "15m",
    "dxy_proxy_lookback_bars": 5,
    "dxy_proxy_ttl_seconds": 300,
    "dxy_proxy_max_bar_age_minutes": 45,
    "dxy_gate_threshold_pct": 0.15,
    "use_event_risk_gate": true,
    "event_risk_hours_before": 4,
    "event_risk_hours_after": 1,
    "event_risk_block_types": ["FOMC", "CPI", "NFP"]
  },
  "iskbets": {
    "min_bigbet_conditions": 2,
    "min_buy_votes": 3,
    "entry_cutoff_et": "14:30",
    "hard_stop_atr_mult": 2.0,
    "stage1_atr_mult": 1.5,
    "trailing_atr_mult": 1.0,
    "time_exit_et": "15:50"
  },
  "bot_name": "finance-analyzer",
  "initial_state": "running",
  "force_entry_enable": true,
  "internals": {
    "process_throttle_secs": 5
  }
}
